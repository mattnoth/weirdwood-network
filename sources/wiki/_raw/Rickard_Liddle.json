  "html": "<div class=\"mw-parser-output\"><table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;font-weight:bold; background: none; line-height: 1.1em;\"><table style=\"width:100%\"><tbody><tr><td style=\"border:none;vertical-align:top;text-align:left;width:50px\"><a href=\"/index.php/House_Liddle\" title=\"House Liddle\"><img alt=\"House Liddle.svg\" src=\"/images/thumb/f/f6/House_Liddle.svg/50px-House_Liddle.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/f/f6/House_Liddle.svg/75px-House_Liddle.svg.png 1.5x, /images/thumb/f/f6/House_Liddle.svg/100px-House_Liddle.svg.png 2x\" /></a></td><td style=\"border:none;vertical-align:middle;text-align:center;padding:0px 7px 5px 7px\">Rickard Liddle<br /><span style=\"font-size:80%;font-weight:normal\"> Little Liddle</span></td><td style=\"border:none;vertical-align:top;text-align:right;width:50px\"><a href=\"/index.php/House_Liddle\" title=\"House Liddle\"><img alt=\"House Liddle.svg\" src=\"/images/thumb/f/f6/House_Liddle.svg/50px-House_Liddle.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/f/f6/House_Liddle.svg/75px-House_Liddle.svg.png 1.5x, /images/thumb/f/f6/House_Liddle.svg/100px-House_Liddle.svg.png 2x\" /></a></td></tr></tbody></table></th></tr><tr><td colspan=\"2\" style=\"text-align:center\"></td></tr><tr><th scope=\"row\">Alias</th><td>\nLittle Liddle<sup id=\"cite_ref-Radwdappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-0\" class=\"reference\"><a href=\"#cite_note-Radwdappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></td></tr><tr><th scope=\"row\">Allegiance</th><td>\n<a href=\"/index.php/House_Liddle\" title=\"House Liddle\">House Liddle</a></td></tr><tr><th scope=\"row\">Culture</th><td>\n<a href=\"/index.php/Northern_mountain_clans\" title=\"Northern mountain clans\">Northern mountain clans</a></td></tr><tr><th scope=\"r