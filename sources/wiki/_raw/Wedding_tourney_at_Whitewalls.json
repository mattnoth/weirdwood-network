th=\"32\" height=\"35\" srcset=\"/images/thumb/b/b4/House_Shawney.svg/48px-House_Shawney.svg.png 1.5x, /images/thumb/b/b4/House_Shawney.svg/64px-House_Shawney.svg.png 2x\" /></a> <a href=\"/index.php/Lord_Shawney\" title=\"Lord Shawney\">Lord Shawney</a><br /></li>\n<li><a href=\"/index.php/House_Smallwood\" title=\"House Smallwood\"><img alt=\"House Smallwood.svg\" src=\"/images/thumb/8/80/House_Smallwood.svg/32px-House_Smallwood.svg.png\" width=\"32\" height=\"35\" srcset=\"/images/thumb/8/80/House_Smallwood.svg/48px-House_Smallwood.svg.png 1.5x, /images/thumb/8/80/House_Smallwood.svg/64px-House_Smallwood.svg.png 2x\" /></a> Lady Smallwood<br /></li>\n<li><a href=\"/index.php/House_Smallwood\" title=\"House Smallwood\"><img alt=\"House Smallwood.svg\" src=\"/images/thumb/8/80/House_Smallwood.svg/32px-House_Smallwood.svg.png\" width=\"32\" height=\"35\" srcset=\"/images/thumb/8/80/House_Smallwood.svg/48px-House_Smallwood.svg.png 1.5x, /images/thumb/8/80/House_Smallwood.svg/64px-House_Smallwood.svg.png 2x\" /></a> <a href=\"/index.php/Lord_Smallwood\" title=\"Lord Smallwood\">Lord Smallwood</a><br /></li>\n<li><a href=\"/index.php/House_Sunderland\" title=\"House Sunderland\"><img alt=\"House Sunderland.svg\" src=\"/images/thumb/8/80/House_Sunderland.svg/32px-House_Sunderland.svg.png\" width=\"32\" height=\"35\" srcset=\"/images/thumb/8/80/House_Sunderland.svg/48px-House_Sunderland.svg.png 1.5x, /images/thumb/8/80/House_Sunderland.svg/64px-House_Sunderland.svg.png 2x\" /></a> <a href=\"/index.php/Lord_Sunderland\" title=\"Lord Sunderland\">Lord Sunderland</a><br /></li>\n<li><a href=\"/index.php/House_Targaryen\" title=\"House Targaryen\"><img alt=\"House Targaryen.svg\" src=\"/images/thumb/1/1e/House_Targaryen.svg/32px-House_Targaryen.svg.png\" width=\"32\" height=\"35\" srcset=\"/images/thumb/1/1e/House_Targaryen.svg/48px-House_Targaryen.svg.png 1.5x, /images/thumb/1/1e/House_Targaryen.svg/64px-House_Targaryen.svg.png 2x\" /></a> Prince <a href=\"/index.php/Aegon_V_Targaryen\" title=\"Aegon V Targaryen\">Aegon Targaryen</a><br /></li>\n<li><a href=\"/index.php/House_Vyrwel\" title=\"House Vyrwel\"><img alt=\"House Vyrwel 2.svg\" src=\"/images/thumb/8/85/House_Vyrwel_2.svg/32px-House_Vyrwel_2.svg.png\" width=\"32\" height=\"35\" srcset=\"/images/thumb/8/85/House_Vyrwel_2.svg/48px-House_Vyrwel_2.svg.png 1.5x, /images/thumb/8/85/House_Vyrwel_2.svg/64px-House_Vyrwel_2.svg.png 2x\" /></a> <a href=\"/index.php/Lady_Vyrwel\" title=\"Lady Vyrwel\">Lady Vyrwel</a><br /></li>\n<li><a href=\"/index.php/House_Vyrwel\" title=\"House Vyrwel\"><img alt=\"House Vyrwel 2.svg\" src=\"/images/thumb/8/85/House_Vyrwel_2.svg/32px-House_Vyrwel_2.svg.png\" width=\"32\" height=\"35\" srcset=\"/images/thumb/8/85/House_Vyrwel_2.svg/48px-House_Vyrwel_2.svg.png 1.5x, /images/thumb/8/85/House_Vyrwel_2.svg/64px-House_Vyrwel_2.svg.png 2x\" /></a> <a href=\"/index.php/Lord_Vyrwel\" title=\"Lord Vyrwel\">Lord Vyrwel</a><br /></li>\n<li><a href=\"/index.php/House_Cuy\" title=\"House Cuy\"><img alt=\"House Cuy.svg\" src=\"/images/thumb/d/d1/House_Cuy.svg/32px-House_Cuy.svg.png\" width=\"32\" height=\"35\" srcset=\"/images/thumb/d/d1/House_Cuy.svg/48px-House_Cuy.svg.png 1.5x, /images/thumb/d/d1/House_Cuy.svg/64px-House_Cuy.svg.png 2x\" /></a> Member of <a href=\"/index.php/House_Cuy\" title=\"House Cuy\">House Cuy</a> (possibly)<br /></li>\n<li><a href=\"/index.php/House_Hasty\" title=\"House Hasty\"><img alt=\"House Hasty.svg\" src=\"/images/thumb/f/f0/House_Hasty.svg/32px-House_Hasty.svg.png\" width=\"32\" height=\"35\" srcset=\"/images/thumb/f/f0/House_Hasty.svg/48px-House_Hasty.svg.png 1.5x, /images/thumb/f/f0/House_Hasty.svg/64px-House_Hasty.svg.png 2x\" /></a> Member of <a href=\"/index.php/House_Hasty\" title=\"House Hasty\">House Hasty</a> (possibly)</li></ul>\n</div>\n<h2><span class=\"mw-headline\" id=\"Quote\">Quote</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Wedding_tourney_at_Whitewalls&amp;action=edit&amp;section=3\" class=\"tw-editsection-onhover\" title=\"Edit section: Quote\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p><b>Duncan</b>: Will there be a melee here?<br />\n</p><p><b>Kyle</b>: A melee? At a <a href=\"/index.php/Marriage\" title=\"Marriage\">marriage</a>? That would be unseemly.<br />\n<b>Maynard</b>: A marriage is a melee, as any married man could tell you.<br />\n</p>\n<b>Uthor</b>: There's just the joust, I fear, but besides the <a href=\"/index.php/Dragon%27s_egg\" class=\"mw-redirect\" title=\"Dragon&#39;s egg\">dragon's egg</a>, Lord <a href=\"/index.php/Ambrose_Butterwell\" title=\"Ambrose Butterwell\">Butterwell</a> has promised thirty <a href=\"/index.php/Currency\" title=\"Currency\">golden dragons</a> for the loser of the final tilt, and ten each for the knights defeated in the round before.<sup id=\"cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-6\" class=\"reference\"><a href=\"#cite_note-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup><p class=\"mw-empty-elt\"></p></div><div class=\"templatequotecite\"><cite>&#8212;<a href=\"/index.php/Duncan_the_Tall\" title=\"Duncan the Tall\">Duncan the Tall</a>, <a href=\"/index.php/Kyle_the_Cat\" title=\"Kyle the Cat\">Kyle the Cat</a>, <a href=\"/index.php/Maynard_Plumm\" title=\"Maynard Plumm\">Maynard Plumm</a>, and <a href=\"/index.php/Uthor_Underleaf\" title=\"Uthor Underleaf\">Uthor Underleaf</a></cite></div>\n</blockquote>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p><b>Uthor</b>: This is only a bit of jousting to celebrate His Lordship's nuptials. A tilt in the yard to mark the tilt between the sheets. Hardly worth the bother for the likes of <a href=\"/index.php/Otho_Bracken\" title=\"Otho Bracken\">Otho Bracken</a>.<br />\n</p><p><b>Kyle</b>: I'll wager <a href=\"/index.php/Ambrose_Butterwell\" title=\"Ambrose Butterwell\">my lord of Butterwell</a> does not take the field either. He will cheer on his champions from his lord's box in the shade.<br />\n</p>\n<b>Glendon</b>: Then he'll see his champions fall, and in the end, he'll hand <a href=\"/index.php/Dragon_egg\" title=\"Dragon egg\">his egg</a> to me.<sup id=\"cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-7\" class=\"reference\"><a href=\"#cite_note-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup><p class=\"mw-empty-elt\"></p></div><div class=\"templatequotecite\"><cite>&#8212;<a href=\"/index.php/Uthor_Underleaf\" title=\"Uthor Underleaf\">Uthor Underleaf</a>, <a href=\"/index.php/Kyle_the_Cat\" title=\"Kyle the Cat\">Kyle the Cat</a>, and <a href=\"/index.php/Glendon_Flowers\" title=\"Glendon Flowers\">Glendon Flowers</a></cite></div>\n</blockquote>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p>Some words are wind. Some words are treason. This is <a href=\"/index.php/Blackfyre_Pretenders\" title=\"Blackfyre Pretenders\">a traitor's</a> tourney, ser.<sup id=\"cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-8\" class=\"reference\"><a href=\"#cite_note-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup></p></div><div class=\"templatequotecite\"><cite>&#8212;<a href=\"/index.php/Aegon_V_Targaryen\" title=\"Aegon V Targaryen\">Aegon Targaryen</a> to <a href=\"/index.php/Duncan_the_Tall\" title=\"Duncan the Tall\">Duncan the Tall</a></cite></div>\n</blockquote>\n<h2><span class=\"mw-headline\" id=\"References\">References</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Wedding_tourney_at_Whitewalls&amp;action=edit&amp;section=4\" class=\"tw-editsection-onhover\" title=\"Edit section: References\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div class=\"references-small\">\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-Rtwoiaf_the_targaryen_kings:_aerys_i.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-Rtwoiaf_the_targaryen_kings:_aerys_i.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-0\">↑</a></span> <span class=\"reference-text\"><i><a href=\"/index.php/The_World_of_Ice_%26_Fire\" title=\"The World of Ice &amp; Fire\">The World of Ice &amp; Fire</a></i>, The Targaryen Kings: Aerys I.</span>\n</li>\n<li id=\"cite_note-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\">2.0</a></sup> <sup><a href=\"#cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-1\">2.1</a></sup> <sup><a href=\"#cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-2\">2.2</a></sup> <sup><a href=\"#cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-3\">2.3</a></sup> <sup><a href=\"#cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-4\">2.4</a></sup> <sup><a href=\"#cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-5\">2.5</a></sup> <sup><a href=\"#cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-6\">2.6</a></sup> <sup><a href=\"#cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-7\">2.7</a></sup> <sup><a href=\"#cite_ref-Rtmk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-8\">2.8</a></sup></span> <span class=\"reference-text\"><i><a href=\"/index.php/The_Mystery_Knight\" title=\"The Mystery Knight\">The Mystery Knight</a></i>.</span>\n</li>\n<li id=\"cite_note-Rawoiafaddam_frey.7B.7B.7B3.7D.7D.7D.