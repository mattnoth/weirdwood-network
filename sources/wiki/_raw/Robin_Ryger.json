{
  "page": "Robin Ryger",
  "html": "<div class=\"mw-parser-output\"><table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;font-weight:bold; background: none; line-height: 1.1em;\"><table style=\"width:100%\"><tbody><tr><td style=\"border:none;vertical-align:top;text-align:left;width:50px\"><a href=\"/index.php/House_Ryger\" title=\"House Ryger\"><img alt=\"House Ryger.svg\" src=\"/images/thumb/3/33/House_Ryger.svg/50px-House_Ryger.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/3/33/House_Ryger.svg/75px-House_Ryger.svg.png 1.5x, /images/thumb/3/33/House_Ryger.svg/100px-House_Ryger.svg.png 2x\" /></a></td><td style=\"border:none;vertical-align:middle;text-align:center;padding:0px 7px 5px 7px\"><span style=\"font-size:80%;font-weight:normal\"> Ser</span><br />Robin Ryger</td><td style=\"border:none;vertical-align:top;text-align:right;width:50px\"><a href=\"/index.php/House_Ryger\" title=\"House Ryger\"><img alt=\"House Ryger.svg\" src=\"/images/thumb/3/33/House_Ryger.svg/50px-House_Ryger.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/3/33/House_Ryger.svg/75px-House_Ryger.svg.png 1.5x, /images/thumb/3/33/House_Ryger.svg/100px-House_Ryger.svg.png 2x\" /></a></td></tr></tbody></table></th></tr><tr><td colspan=\"2\" class=\"infobox-image\" style=\"text-align:center\">\n<a href=\"/index.php/File:Robin_ryger.jpg\" class=\"image\"><img alt=\"Robin ryger.jpg\" src=\"/images/thumb/2/23/Robin_ryger.jpg/300px-Robin_ryger.jpg\" width=\"300\" height=\"375\" srcset=\"/images/thumb/2/23/Robin_ryger.jpg/450px-Robin_ryger.jpg 1.5x, /images/thumb/2/23/Robin_ryger.jpg/600px-Robin_ryger.jpg 2x\" /></a><div>Robin Ryger by TheMarkyGallery ©</div></td></tr><tr><td colspan=\"2\" style=\"text-align:center\">\n<hr /></td></tr><tr><th scope=\"row\">Titles</th><td>\n<div class=\"plainlist\"><ul><li><a href=\"/index.php/Knight\" title=\"Knight\">Ser</a></li><li><a href=\"/index.php/Captain_of_the_guards\" title=\"Captain of the guards\">Captain of the guards</a> at <a href=\"/index.php/Riverrun\" title=\"Riverrun\">Riverrun</a></li></ul></div></td></tr><tr><th scope=\"row\">Allegiances</th><td>\n<div class=\"plainlist\"><ul><li><a href=\"/index.php/House_Ryger\" title=\"House Ryger\">House Ryger</a></li><li><a href=\"/index.php/House_Tully\" title=\"House Tully\">House Tully</a></li><li><a href=\"/index.php/Night%27s_Watch\" title=\"Night&#39;s Watch\">Night's Watch</a></li></ul></div></td></tr><tr><th scope=\"row\">Culture</th><td>\n<a href=\"/index.php/Rivermen\" title=\"Rivermen\">Rivermen</a></td></tr><tr><th scope=\"row\">Born</th><td>\n<a href=\"/index.php/Years_after_Aegon%27s_Conquest#Year_238_After_the_Conquest\" title=\"Years after Aegon&#39;s Conquest\">238</a>–<a href=\"/index.php/Years_after_Aegon%27s_Conquest#Year_240_After_the_Conquest\" title=\"Years after Aegon&#39;s Conquest\">240&#160;AC</a> (roughly)<sup id=\"cite_ref-1\" class=\"reference\"><a href=\"#cite_note-1\">&#91;1&#93;</a></sup></td></tr><tr><th scope=\"row\">Books</th><td>\n<div class=\"plainlist\"><ul><li><i><a href=\"/index.php/A_Game_of_Thrones\" title=\"A Game of Thrones\">A Game of Thrones</a></i> (appears)</li><li><i><a href=\"/index.php/A_Clash_of_Kings\" title=\"A Clash of Kings\">A Clash of Kings</a></i> (appears)</li><li><i><a href=\"/index.php/A_Storm_of_Swords\" title=\"A Storm of Swords\">A Storm of Swords</a></i> (appears)</li><li><i><a href=\"/index.php/A_Feast_for_Crows\" title=\"A Feast for Crows\">A Feast for Crows</a></i> (appears)</li><li><i><a href=\"/index.php/A_Dance_with_Dragons\" title=\"A Dance with Dragons\">A Dance with Dragons</a></i> (appendix)</li></ul></div></td></tr></tbody></table>\n<p><b>Robin Ryger</b> is a <a href=\"/index.php/Knight\" title=\"Knight\">knight</a> of <a href=\"/index.php/House_Ryger\" title=\"House Ryger\">House Ryger</a> who serves as the <a href=\"/index.php/House_Tully_guards\" title=\"House Tully guards\">captain of the guard</a> at <a href=\"/index.php/Riverrun\" title=\"Riverrun\">Riverrun</a>.<sup id=\"cite_ref-Ragotappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\" class=\"reference\"><a href=\"#cite_note-Ragotappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\" lang=\"en\" dir=\"ltr\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Appearance_and_Character\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Appearance and Character</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#Recent_Events\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Recent Events</span></a>\n<ul>\n<li class=\"toclevel-2 tocsection-3\"><a href=\"#A_Game_of_Thrones\"><span class=\"tocnumber\">2.1</span> <span class=\"toctext\"><i>A Game of Thrones</i></span></a></li>\n<li class=\"toclevel-2 tocsection-4\"><a href=\"#A_Clash_of_Kings\"><span class=\"tocnumber\">2.2</span> <span class=\"toctext\"><i>A Clash of Kings</i></span></a></li>\n<li class=\"toclevel-2 tocsection-5\"><a href=\"#A_Storm_of_Swords\"><span class=\"tocnumber\">2.3</span> <span class=\"toctext\"><i>A Storm of Swords</i></span></a></li>\n<li class=\"toclevel-2 tocsection-6\"><a href=\"#A_Feast_for_Crows\"><span class=\"tocnumber\">2.4</span> <span class=\"toctext\"><i>A Feast for Crows</i></span></a></li>\n</ul>\n</li>\n<li class=\"toclevel-1 tocsection-7\"><a href=\"#Quotes_by_Robin\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Quotes by Robin</span></a></li>\n<li class=\"toclevel-1 tocsection-8\"><a href=\"#Quotes_about_Robin\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">Quotes about Robin</span></a></li>\n<li class=\"toclevel-1 tocsection-9\"><a href=\"#References\"><span class=\"tocnumber\">5</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h2><span class=\"mw-headline\" id=\"Appearance_and_Character\">Appearance and Character</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Robin_Ryger&amp;action=edit&amp;section=1\" class=\"tw-editsection-onhover\" title=\"Edit section: Appearance and Character\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>Robin is a stocky man with a bald head, bushy grey eyebrows, and brawny arms.<sup id=\"cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-0\" class=\"reference\"><a href=\"#cite_note-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup> Like Lord <a href=\"/index.php/Hoster_Tully\" title=\"Hoster Tully\">Hoster Tully</a>, Ser <a href=\"/index.php/Desmond_Grell\" title=\"Desmond Grell\">Desmond Grell</a>, and <a href=\"/index.php/Utherydes_Wayn\" title=\"Utherydes Wayn\">Utherydes Wayn</a>, he is an old man.<sup id=\"cite_ref-Racok39.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-0\" class=\"reference\"><a href=\"#cite_note-Racok39.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\">&#91;4&#93;</a></sup>\n</p><p>Robin was known as a tenacious fighter in his prime.<sup id=\"cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-1\" class=\"reference\"><a href=\"#cite_note-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup>\n</p><p>Robin wears mail under his white surcoat, which is decorated with a weeping willow embroidered in pale green. He fastens his cloak with a <a href=\"/index.php/Silver\" title=\"Silver\">silver</a> <a href=\"/index.php/Trout\" title=\"Trout\">trout</a>.<sup id=\"cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-2\" class=\"reference\"><a href=\"#cite_note-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Recent_Events\">Recent Events</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Robin_Ryger&amp;action=edit&amp;section=2\" class=\"tw-editsection-onhover\" title=\"Edit section: Recent Events\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span class=\"mw-headline\" id=\"A_Game_of_Thrones\"><i>A Game of Thrones</i></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Robin_Ryger&amp;action=edit&amp;section=3\" class=\"tw-editsection-onhover\" title=\"Edit section: A Game of Thrones\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>Having served years as <a href=\"/index.php/Knight_of_the_Gate\" title=\"Knight of the Gate\">Knight of the Gate</a>, Ser <a href=\"/index.php/Brynden_Tully\" title=\"Brynden Tully\">Brynden Tully</a> speaks with Robin when he returns to <a href=\"/index.php/Riverrun\" title=\"Riverrun\">Riverrun</a>.<sup id=\"cite_ref-Ragot71.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-0\" class=\"reference\"><a href=\"#cite_note-Ragot71.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\">&#91;5&#93;</a></sup>\n</p>\n<h3><span class=\"mw-headline\" id=\"A_Clash_of_Kings\"><i>A Clash of Kings</i></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Robin_Ryger&amp;action=edit&amp;section=4\" class=\"tw-editsection-onhover\" title=\"Edit section: A Clash of Kings\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>Ser Robin brings Ser <a href=\"/index.php/Cleos_Frey\" title=\"Cleos Frey\">Cleos Frey</a> to the <a href=\"/index.php/Great_Hall_of_Riverrun\" title=\"Great Hall of Riverrun\">Great Hall of Riverrun</a> to hear <a href=\"/index.php/Robb_Stark\" title=\"Robb Stark\">Robb Stark</a>'s terms for his release and for peace between the <a href=\"/index.php/King_in_the_North\" title=\"King in the North\">King in the North</a> and King <a href=\"/index.php/Joffrey_Baratheon\" title=\"Joffrey Baratheon\">Joffrey I Baratheon</a>. Robb orders Robin to make sure that Cleos has a good meal and clean clothing before the envoy departs for <a href=\"/index.php/King%27s_Landing\" title=\"King&#39;s Landing\">King's Landing</a>.<sup id=\"cite_ref-Racok7.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-0\" class=\"reference\"><a href=\"#cite_note-Racok7.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-6\">&#91;6&#93;</a></sup>\n</p><p>Robin is introduced to <a href=\"/index.php/Brienne_Tarth\" title=\"Brienne Tarth\">Brienne Tarth</a> when she and Catelyn return from <a href=\"/index.php/Siege_of_Storm%27s_End_(299)\" title=\"Siege of Storm&#39;s End (299)\">Storm's End</a>. Robin asks about the manner of <a href=\"/index.php/Renly_Baratheon\" title=\"Renly Baratheon\">Renly Baratheon</a>'s death.<sup id=\"cite_ref-Racok39.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-1\" class=\"reference\"><a href=\"#cite_note-Racok39.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\">&#91;4&#93;</a></sup>\n</p>\n<h3><span class=\"mw-headline\" id=\"A_Storm_of_Swords\"><i>A Storm of Swords</i></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Robin_Ryger&amp;action=edit&amp;section=5\" class=\"tw-editsection-onhover\" title=\"Edit section: A Storm of Swords\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>Robin is sent by Ser <a href=\"/index.php/Desmond_Grell\" title=\"Desmond Grell\">Desmond Grell</a><sup id=\"cite_ref-Rasos2.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_7-0\" class=\"reference\"><a href=\"#cite_note-Rasos2.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-7\">&#91;7&#93;</a></sup> to re-capture Ser <a href=\"/index.php/Jaime_Lannister\" title=\"Jaime Lannister\">Jaime Lannister</a> after <a href=\"/index.php/Catelyn_Stark\" title=\"Catelyn Stark\">Catelyn Stark</a> sets him free, chasing after the Kingslayer in a river galley. After Robin refuses Jaime's offer of single combat, <a href=\"/index.php/Brienne_Tarth\" title=\"Brienne Tarth\">Brienne of Tarth</a>, Jaime's protector, sinks Robin's ship with a rock in the <a href=\"/index.php/Red_Fork\" title=\"Red Fork\">Red Fork</a>.<sup id=\"cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-3\" class=\"reference\"><a href=\"#cite_note-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup> Robin and his men walk back to Riverrun footweary and drenched.<sup id=\"cite_ref-Rasos2.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_7-1\" class=\"reference\"><a href=\"#cite_note-Rasos2.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-7\">&#91;7&#93;</a></sup>\n</p>\n<h3><span class=\"mw-headline\" id=\"A_Feast_for_Crows\"><i>A Feast for Crows</i></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Robin_Ryger&amp;action=edit&amp;section=6\" class=\"tw-editsection-onhover\" title=\"Edit section: A Feast for Crows\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>After the <a href=\"/index.php/Siege_of_Riverrun\" title=\"Siege of Riverrun\">surrender of Riverrun</a>, Robin and Ser <a href=\"/index.php/Desmond_Grell\" title=\"Desmond Grell\">Desmond Grell</a> ask to join the <a href=\"/index.php/Night%27s_Watch\" title=\"Night&#39;s Watch\">Night's Watch</a>. Both are to be escorted to <a href=\"/index.php/Maidenpool\" title=\"Maidenpool\">Maidenpool</a> by a dozen of the <a href=\"/index.php/Mountain%27s_men\" title=\"Mountain&#39;s men\">Mountain's men</a> under the command of <a href=\"/index.php/Rafford\" title=\"Rafford\">Raff the Sweetling</a>.<sup id=\"cite_ref-Raffc44.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_8-0\" class=\"reference\"><a href=\"#cite_note-Raffc44.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-8\">&#91;8&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Quotes_by_Robin\">Quotes by Robin</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Robin_Ryger&amp;action=edit&amp;section=7\" class=\"tw-editsection-onhover\" title=\"Edit section: Quotes by Robin\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p><b>Jaime</b>: Come to wish me godspeed, Ser Robin?<br />\n</p><p><b>Robin</b>: Come to take you back, Kingslayer. How is it that you've lost your golden hair?<br />\n</p>\n<b>Jaime</b>: I hope to blind my enemies with the sheen off my head. It's worked well enough for you.<sup id=\"cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-4\" class=\"reference\"><a href=\"#cite_note-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup><p class=\"mw-empty-elt\"></p></div><div class=\"templatequotecite\"><cite>&#8212;<a href=\"/index.php/Jaime_Lannister\" title=\"Jaime Lannister\">Jaime Lannister</a> and Robin</cite></div>\n</blockquote>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p><b>Robin</b>: Say what you will, Kingslayer, but say it quickly.<br />\n</p><p><b>Jaime</b>: I know a better way to settle this—single combat. You and I.<br />\n<b>Robin</b>: I was not born this morning, Lannister.<br />\n<b>Jaime</b>: No, but you're like to die this afternoon. I'll fight you in chains. What could you fear?<br />\n</p>\n<b>Robin</b>: Not you, ser. If the choice were mine, I'd like nothing better, but I am commanded to bring you back alive if possible.<sup id=\"cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-5\" class=\"reference\"><a href=\"#cite_note-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup><p class=\"mw-empty-elt\"></p></div><div class=\"templatequotecite\"><cite>&#8212;Robin and <a href=\"/index.php/Jaime_Lannister\" title=\"Jaime Lannister\">Jaime Lannister</a></cite></div>\n</blockquote>\n<h2><span class=\"mw-headline\" id=\"Quotes_about_Robin\">Quotes about Robin</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Robin_Ryger&amp;action=edit&amp;section=8\" class=\"tw-editsection-onhover\" title=\"Edit section: Quotes about Robin\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p>In his day Ser Robin Ryger had been a notably tenacious fighter, but his day was done; he was of an age with <a href=\"/index.php/Hoster_Tully\" title=\"Hoster Tully\">Hoster Tully</a>, and had grown old with his lord.<sup id=\"cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-6\" class=\"reference\"><a href=\"#cite_note-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup></p></div><div class=\"templatequotecite\"><cite>&#8212;thoughts of <a href=\"/index.php/Jaime_Lannister\" title=\"Jaime Lannister\">Jaime Lannister</a></cite></div>\n</blockquote>\n<h2><span class=\"mw-headline\" id=\"References\">References</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Robin_Ryger&amp;action=edit&amp;section=9\" class=\"tw-editsection-onhover\" title=\"Edit section: References\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div class=\"references-small\" style=\"-webkit-column-width:200px; -moz-column-width:200px; column-width:200px; -webkit-column-count:2; -moz-column-count:2; column-count:2;\">\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">↑</a></span> <span class=\"reference-text\"><i>See the <a href=\"/index.php/Years_after_Aegon%27s_Conquest/Calculations_Ages_(Continued3)#Robin_Ryger\" title=\"Years after Aegon&#39;s Conquest/Calculations Ages (Continued3)\">Robin Ryger</a> calculation.</i></span>\n</li>\n<li id=\"cite_note-Ragotappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-Ragotappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\">↑</a></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Game_of_Thrones\" title=\"A Game of Thrones\">A Game of Thrones</a></i>, <a href=\"/index.php/A_Game_of_Thrones-Appendix\" title=\"A Game of Thrones-Appendix\">Appendix</a>.</span>\n</li>\n<li id=\"cite_note-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-0\">3.0</a></sup> <sup><a href=\"#cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-1\">3.1</a></sup> <sup><a href=\"#cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-2\">3.2</a></sup> <sup><a href=\"#cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-3\">3.3</a></sup> <sup><a href=\"#cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-4\">3.4</a></sup> <sup><a href=\"#cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-5\">3.5</a></sup> <sup><a href=\"#cite_ref-Rasos1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-6\">3.6</a></sup></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Storm_of_Swords\" title=\"A Storm of Swords\">A Storm of Swords</a></i>, <a href=\"/index.php/A_Storm_of_Swords-Chapter_1\" title=\"A Storm of Swords-Chapter 1\">Chapter 1</a>, Jaime I.</span>\n</li>\n<li id=\"cite_note-Racok39.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Racok39.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-0\">4.0</a></sup> <sup><a href=\"#cite_ref-Racok39.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-1\">4.1</a></sup></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Clash_of_Kings\" title=\"A Clash of Kings\">A Clash of Kings</a></i>