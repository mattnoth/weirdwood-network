>\n<li><a href=\"/index.php/Dragon_skull\" class=\"mw-redirect\" title=\"Dragon skull\">Dragon skull</a></li>\n<li><a href=\"/index.php/First_Men\" title=\"First Men\">First Men</a></li>\n<li><a href=\"/index.php/Hand_of_the_King\" title=\"Hand of the King\">Hand of the King</a></li>\n<li><a href=\"/index.php/Ice\" title=\"Ice\">Ice</a></li>\n<li><a href=\"/index.php/Iron_Throne\" title=\"Iron Throne\">Iron Throne</a></li>\n<li><i><a href=\"/index.php/Khal\" title=\"Khal\">Khal</a></i></li>\n<li><a href=\"/index.php/King%27s_justice_(concept)\" title=\"King&#39;s justice (concept)\">King's justice</a></li>\n<li><a href=\"/index.php/Kingsguard\" title=\"Kingsguard\">Kingsguard</a></li>\n<li><a href=\"/index.php/Master_of_whisperers\" title=\"Master of whisperers\">Master of whisperers</a></li>\n<li><a href=\"/index.php/Others\" title=\"Others\">Others</a></li>\n<li><a href=\"/index.php/Slaver\" class=\"mw-redirect\" title=\"Slaver\">Slaver</a></li>\n<li><a href=\"/index.php/Sworn_Brother\" title=\"Sworn Brother\">Sworn Brother</a></li>\n<li><a href=\"/index.php/Unsullied\" title=\"Unsullied\">Unsullied</a></li>\n<li><a href=\"/index.php/Usurper\" title=\"Usurper\">Usurper</a></li>\n<li><a href=\"/index.php/Warden_of_the_East\" title=\"Warden of the East\">Warden of the East</a></li>\n<li><a href=\"/index.php/Warden_of_the_West\" title=\"Warden of the West\">Warden of the West</a></li>\n<li><a href=\"/index.php/Wheelhouse\" title=\"Wheelhouse\">Wheelhouse</a></li></ul>\n</div>\n</td></tr></tbody></table>\n<h2><span class=\"mw-headline\" id=\"References\">References</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=A_Game_of_Thrones-Chapter_12&amp;action=edit&amp;section=4\" class=\"tw-editsection-onhover\" title=\"Edit section: References\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>This page uses content from <b><a rel=\"nofollow\" 