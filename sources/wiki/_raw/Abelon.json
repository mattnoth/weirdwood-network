  "html": "<div class=\"mw-parser-output\"><table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;font-weight:bold; background: none; line-height: 1.1em;\"><table style=\"width:100%\"><tbody><tr><td style=\"border:none;vertical-align:top;text-align:left;width:50px\"><a href=\"/index.php/Maesters\" title=\"Maesters\"><img alt=\"Maester.svg\" src=\"/images/thumb/4/46/Maester.svg/50px-Maester.svg.png\" width=\"50\" height=\"50\" srcset=\"/images/thumb/4/46/Maester.svg/75px-Maester.svg.png 1.5x, /images/thumb/4/46/Maester.svg/100px-Maester.svg.png 2x\" /></a></td><td style=\"border:none;vertical-align:middle;text-align:center;padding:0px 7px 5px 7px\"><span style=\"font-size:80%;font-weight:normal\"> Archmaester</span><br />Abelon</td><td style=\"border:none;vertical-align:top;text-align:right;width:50px\"><a href=\"/index.php/Maesters\" title=\"Maesters\"><img alt=\"Archmaester.svg\" src=\"/images/thumb/a/ae/Archmaester.svg/50px-Archmaester.svg.png\" width=\"50\" height=\"50\" srcset=\"/images/thumb/a/ae/Archmaester.svg/75px-Archmaester.svg.png 1.5x, /images/thumb/a/ae/Archmaester.svg/100px-Archmaester.svg.png 2x\" /></a></td></tr></tbody></table></th></tr><tr><td colspan=\"2\" style=\"text-align:center\"></td></tr><tr><th scope=\"row\">Title</th><td>\n<a href=\"/index.php/Archmaester\" class=\"mw-redirect\" title=\"Archmaester\">Archmaester</a></td></tr><tr><th scope=\"row\">Allegiance</th><td>\n<a href=\"/index.php/Citadel\" title=\"Citadel\">The Citadel</a></td></tr><tr><th scope=\"row\">Culture</th><td>\n<a href=\"/index.php/Westeros\" title=\"Westeros\">Westerosi</a></td></tr><tr><th scope=\"row\">Book</th><td>\n<i><a href=\"/index.php/Fire_%26_Blood\" title=\"Fire &amp; Blood\">Fire &amp; Blood</a></i> (mentioned)</td></tr></tbody></table>\n<p><b>Abelon</b> was an <a href=\"/index.php/Archmaester\" class=\"mw-redirect\" titl