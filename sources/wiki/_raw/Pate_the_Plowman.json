  "html": "<div class=\"mw-parser-output\"><div role=\"note\" class=\"hatnote navigation-not-searchable\" style=\"font-style: italic;padding-left: 1.6em;margin-bottom: 0.5em;\">For others with the same name, see <a href=\"/index.php/Pate\" title=\"Pate\">Pate</a>.</div>\n<table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;font-weight:bold; background: none; line-height: 1.1em;\"><table style=\"width:100%\"><tbody><tr><td style=\"border:none;vertical-align:top;text-align:left;width:50px\"><a href=\"/index.php/House_Moreland\" title=\"House Moreland\"><img alt=\"House Moreland.svg\" src=\"/images/thumb/6/64/House_Moreland.svg/50px-House_Moreland.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/6/64/House_Moreland.svg/75px-House_Moreland.svg.png 1.5x, /images/thumb/6/64/House_Moreland.svg/100px-House_Moreland.svg.png 2x\" /></a></td><td style=\"border:none;vertical-align:middle;text-align:center;padding:0px 7px 5px 7px\">Pate the Plowman</td><td style=\"border:none;vertical-align:top;text-align:right;width:50px\"><a href=\"/index.php/House_Moreland\" title=\"House Moreland\"><img alt=\"House Moreland.svg\" src=\"/images/thumb/6/64/House_Moreland.svg/50px-House_Moreland.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/6/64/House_Moreland.svg/75px-House_Moreland.svg.png 1.5x, /images/thumb/6/64/House_Moreland.svg/100px-House_Moreland.svg.png 2x\" /></a></td></tr></tbody></table></th></tr><tr><td colspan=\"2\" style=\"text-align:center\"></td></tr><tr><th scope=\"row\">Alias</th><td>\nPate the Plowman</td></tr><tr><th scope=\"row\">Allegiance</th><td>\n<a href=\"/index.php/House_Moreland\" title=\"House Moreland\">House Moreland</a></td></tr><tr><th scope=\"row\">Race</th><td>\n<a href=\"/index.php/First_Men\" title=\"First Men\">First Men</a></td></tr><tr><th scope=\"row\">Culture</th><td>\n<a href=\"/index.