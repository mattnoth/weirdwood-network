{
  "page": "Benjicot Blackwood",
  "html": "<div class=\"mw-parser-output\"><div role=\"note\" class=\"hatnote navigation-not-searchable\" style=\"font-style: italic;padding-left: 1.6em;margin-bottom: 0.5em;\">\"Ben Blackwood\" redirects here. For the son of Lord Tytos Blackwood, see <a href=\"/index.php/Edmund_Blackwood\" title=\"Edmund Blackwood\">Edmund Blackwood</a>.</div>\n<table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;font-weight:bold; background: none; line-height: 1.1em;\"><table style=\"width:100%\"><tbody><tr><td style=\"border:none;vertical-align:top;text-align:left;width:50px\"><a href=\"/index.php/House_Blackwood\" title=\"House Blackwood\"><img alt=\"House Blackwood.svg\" src=\"/images/thumb/e/e1/House_Blackwood.svg/50px-House_Blackwood.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/e/e1/House_Blackwood.svg/75px-House_Blackwood.svg.png 1.5x, /images/thumb/e/e1/House_Blackwood.svg/100px-House_Blackwood.svg.png 2x\" /></a></td><td style=\"border:none;vertical-align:middle;text-align:center;padding:0px 7px 5px 7px\"><span style=\"font-size:80%;font-weight:normal\"> Lord</span><br />Benjicot Blackwood</td><td style=\"border:none;vertical-align:top;text-align:right;width:50px\"><a href=\"/index.php/House_Blackwood\" title=\"House Blackwood\"><img alt=\"House Blackwood.svg\" src=\"/images/thumb/e/e1/House_Blackwood.svg/50px-House_Blackwood.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/e/e1/House_Blackwood.svg/75px-House_Blackwood.svg.png 1.5x, /images/thumb/e/e1/House_Blackwood.svg/100px-House_Blackwood.svg.png 2x\" /></a></td></tr></tbody></table></th></tr><tr><td colspan=\"2\" class=\"infobox-image\" style=\"text-align:center\">\n<a href=\"/index.php/File:Benjicot_Blackwood_Muddy_Mess_(The_Rise_of_the_Dragon).jpg\" class=\"image\"><img alt=\"Benjicot Blackwood Muddy Mess (The Rise of the Dragon).jpg\" src=\"/images/thumb/9/9d/Benjicot_Blackwood_Muddy_Mess_%28The_Rise_of_the_Dragon%29.jpg/350px-Benjicot_Blackwood_Muddy_Mess_%28The_Rise_of_the_Dragon%29.jpg\" width=\"350\" height=\"464\" srcset=\"/images/thumb/9/9d/Benjicot_Blackwood_Muddy_Mess_%28The_Rise_of_the_Dragon%29.jpg/525px-Benjicot_Blackwood_Muddy_Mess_%28The_Rise_of_the_Dragon%29.jpg 1.5x, /images/thumb/9/9d/Benjicot_Blackwood_Muddy_Mess_%28The_Rise_of_the_Dragon%29.jpg/700px-Benjicot_Blackwood_Muddy_Mess_%28The_Rise_of_the_Dragon%29.jpg 2x\" /></a><div>Benjicot Blackwood by Ertaç Altinöz for <i><a href=\"/index.php/The_Rise_of_the_Dragon\" title=\"The Rise of the Dragon\">The Rise of the Dragon</a></i></div></td></tr><tr><td colspan=\"2\" style=\"text-align:center\">\n<hr /></td></tr><tr><th scope=\"row\">Aliases</th><td>\n<div class=\"plainlist\"><ul><li>Bloody Ben<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-0\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></li><li>Bloody Ben Blackwood<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-1\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></li></ul></div></td></tr><tr><th scope=\"row\">Title</th><td>\n<a href=\"/index.php/Lord_of_Raventree_Hall\" class=\"mw-redirect\" title=\"Lord of Raventree Hall\">Lord of Raventree Hall</a><sup id=\"cite_ref-Rfabthe_dying_of_the_dragons_-_rhaenyra_triumphant.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\" class=\"reference\"><a href=\"#cite_note-Rfabthe_dying_of_the_dragons_-_rhaenyra_triumphant.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup></td></tr><tr><th scope=\"row\">Allegiances</th><td>\n<div class=\"plainlist\"><ul><li><a href=\"/index.php/House_Blackwood\" title=\"House Blackwood\">House Blackwood</a></li><li><a href=\"/index.php/Blacks\" title=\"Blacks\">Blacks</a></li><li><a href=\"/index.php/Lads\" title=\"Lads\">Lads</a></li></ul></div></td></tr><tr><th scope=\"row\">Culture</th><td>\n<a href=\"/index.php/Rivermen\" title=\"Rivermen\">Rivermen</a></td></tr><tr><th scope=\"row\">Born</th><td>\n<a href=\"/index.php/Years_after_Aegon%27s_Conquest#Year_118_After_the_Conquest\" title=\"Years after Aegon&#39;s Conquest\">118&#160;AC</a><sup id=\"cite_ref-Calculation_3-0\" class=\"reference\"><a href=\"#cite_note-Calculation-3\">&#91;3&#93;</a></sup></td></tr><tr><th scope=\"row\">Died</th><td>\n<a href=\"/index.php/136_AC\" title=\"136 AC\">136</a>–<a href=\"/index.php/Years_after_Aegon%27s_Conquest#Year_206_After_the_Conquest\" title=\"Years after Aegon&#39;s Conquest\">206&#160;AC</a><sup id=\"cite_ref-Calculation_3-1\" class=\"reference\"><a href=\"#cite_note-Calculation-3\">&#91;3&#93;</a></sup></td></tr><tr><th scope=\"row\">Father</th><td>\n<a href=\"/index.php/Samwell_Blackwood\" title=\"Samwell Blackwood\">Samwell Blackwood</a></td></tr><tr><th scope=\"row\">Books</th><td>\n<div class=\"plainlist\"><ul><li><i><a href=\"/index.php/The_World_of_Ice_%26_Fire\" title=\"The World of Ice &amp; Fire\">The World of Ice &amp; Fire</a></i> (mentioned)</li><li><i><a href=\"/index.php/Fire_%26_Blood\" title=\"Fire &amp; Blood\">Fire &amp; Blood</a></i> (mentioned)</li><li><i><a href=\"/index.php/The_Rise_of_the_Dragon\" title=\"The Rise of the Dragon\">The Rise of the Dragon</a></i> (mentioned)</li><li><i><a href=\"/index.php/The_Princess_and_the_Queen\" title=\"The Princess and the Queen\">The Princess and the Queen</a></i> (mentioned)</li></ul></div></td></tr></tbody></table>\n<p><b>Benjicot Blackwood</b>, known as <b>Bloody Ben</b> by his men,<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-2\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> was the Lord of <a href=\"/index.php/Raventree_Hall\" title=\"Raventree Hall\">Raventree Hall</a> and the head of <a href=\"/index.php/House_Blackwood\" title=\"House Blackwood\">House Blackwood</a> during the <a href=\"/index.php/Dance_of_the_Dragons\" title=\"Dance of the Dragons\">Dance of the Dragons</a> and during the reign of King <a href=\"/index.php/Aegon_III_Targaryen\" title=\"Aegon III Targaryen\">Aegon III Targaryen</a>.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-3\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\" lang=\"en\" dir=\"ltr\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Appearance_and_Character\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Appearance and Character</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#History\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">History</span></a>\n<ul>\n<li class=\"toclevel-2 tocsection-3\"><a href=\"#Dance_of_the_Dragons\"><span class=\"tocnumber\">2.1</span> <span class=\"toctext\">Dance of the Dragons</span></a></li>\n<li class=\"toclevel-2 tocsection-4\"><a href=\"#Regency_of_King_Aegon_III\"><span class=\"tocnumber\">2.2</span> <span class=\"toctext\">Regency of King Aegon III</span></a></li>\n<li class=\"toclevel-2 tocsection-5\"><a href=\"#Later_life\"><span class=\"tocnumber\">2.3</span> <span class=\"toctext\">Later life</span></a></li>\n</ul>\n</li>\n<li class=\"toclevel-1 tocsection-6\"><a href=\"#Family\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Family</span></a></li>\n<li class=\"toclevel-1 tocsection-7\"><a href=\"#References\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h2><span class=\"mw-headline\" id=\"Appearance_and_Character\">Appearance and Character</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Benjicot_Blackwood&amp;action=edit&amp;section=1\" class=\"tw-editsection-onhover\" title=\"Edit section: Appearance and Character\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>Benjicot was tall and slim, with a shy and sensitive manner. When armored for battle, however, he was quite fierce.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-4\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"History\">History</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Benjicot_Blackwood&amp;action=edit&amp;section=2\" class=\"tw-editsection-onhover\" title=\"Edit section: History\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span class=\"mw-headline\" id=\"Dance_of_the_Dragons\">Dance of the Dragons</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Benjicot_Blackwood&amp;action=edit&amp;section=3\" class=\"tw-editsection-onhover\" title=\"Edit section: Dance of the Dragons\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:352px;\"><a href=\"/index.php/File:Benjicot_Blackwood_by_Riotarttherite.png\" class=\"image\"><img alt=\"\" src=\"/images/thumb/d/da/Benjicot_Blackwood_by_Riotarttherite.png/350px-Benjicot_Blackwood_by_Riotarttherite.png\" width=\"350\" height=\"353\" class=\"thumbimage\" srcset=\"/images/thumb/d/da/Benjicot_Blackwood_by_Riotarttherite.png/525px-Benjicot_Blackwood_by_Riotarttherite.png 1.5x, /images/thumb/d/da/Benjicot_Blackwood_by_Riotarttherite.png/700px-Benjicot_Blackwood_by_Riotarttherite.png 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/index.php/File:Benjicot_Blackwood_by_Riotarttherite.png\" class=\"internal\" title=\"Enlarge\"></a></div>Benjicot Blackwood by © <a rel=\"nofollow\" class=\"external text\" href=\"https://riotarttherite.tumblr.com/\">Riotarttherite</a></div></div></div>\n<p>When he was eleven years old, Benjicot became the head of <a href=\"/index.php/House_Blackwood\" title=\"House Blackwood\">his House</a> after the death of his father, Lord <a href=\"/index.php/Samwell_Blackwood\" title=\"Samwell Blackwood\">Samwell Blackwood</a>, in the <a href=\"/index.php/Battle_of_the_Burning_Mill\" title=\"Battle of the Burning Mill\">Battle of the Burning Mill</a> in <a href=\"/index.php/129_AC\" title=\"129 AC\">129&#160;AC</a> during the <a href=\"/index.php/Dance_of_the_Dragons\" title=\"Dance of the Dragons\">Dance of the Dragons</a>.<sup id=\"cite_ref-Rfabthe_dying_of_the_dragons_-_the_red_dragon_and_the_gold.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-0\" class=\"reference\"><a href=\"#cite_note-Rfabthe_dying_of_the_dragons_-_the_red_dragon_and_the_gold.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\">&#91;4&#93;</a></sup> A member of the <a href=\"/index.php/Blacks\" title=\"Blacks\">blacks</a>, Benjicot participated in the <a href=\"/index.php/Battle_by_the_Lakeshore\" title=\"Battle by the Lakeshore\">Battle by the Lakeshore</a> the following year. Although the soldiers from the <a href=\"/index.php/Riverlands\" title=\"Riverlands\">riverlands</a> and the <a href=\"/index.php/North\" title=\"North\">north</a> defeated the <a href=\"/index.php/Westermen\" title=\"Westermen\">westermen</a> army in the battle, Benjicot wept when he saw all of the dead.<sup id=\"cite_ref-Rfabthe_dying_of_the_dragons_-_rhaenyra_triumphant.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-1\" class=\"reference\"><a href=\"#cite_note-Rfabthe_dying_of_the_dragons_-_rhaenyra_triumphant.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup> \n</p><p>When Prince <a href=\"/index.php/Aemond_Targaryen\" title=\"Aemond Targaryen\">Aemond Targaryen</a> raided the riverlands atop <a href=\"/index.php/Vhagar\" title=\"Vhagar\">Vhagar</a>, Benjicot asked Queen <a href=\"/index.php/Rhaenyra_Targaryen\" title=\"Rhaenyra Targaryen\">Rhaenyra Targaryen</a> to protect the riverlords with her <a href=\"/index.php/Dragon\" title=\"Dragon\">dragons</a>, but she remained in <a href=\"/index.php/King%27s_Landing\" title=\"King&#39;s Landing\">King's Landing</a>.<sup id=\"cite_ref-Rfabthe_dying_of_the_dragons_-_rhaenyra_triumphant.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-2\" class=\"reference\"><a href=\"#cite_note-Rfabthe_dying_of_the_dragons_-_rhaenyra_triumphant.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>Benjicot's men hunted the foragers of Ser <a href=\"/index.php/Criston_Cole\" title=\"Criston Cole\">Criston Cole</a> after the Kingmaker left <a href=\"/index.php/Harrenhal\" title=\"Harrenhal\">Harrenhal</a>.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-5\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> Benjicot commanded the center during the <a href=\"/index.php/Second_Battle_of_Tumbleton\" title=\"Second Battle of Tumbleton\">Second Battle of Tumbleton</a>.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-6\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> Following the battle, he had one of his longbowmen, <a href=\"/index.php/Billy_Burley\" title=\"Billy Burley\">Billy Burley</a>, put three arrows through the eye of the weakened dragon <a href=\"/index.php/Tessarion\" title=\"Tessarion\">Tessarion</a>.<sup id=\"cite_ref-Rfabthe_dying_of_the_dragons_-_rhaenyra_overthrown.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-0\" class=\"reference\"><a href=\"#cite_note-Rfabthe_dying_of_the_dragons_-_rhaenyra_overthrown.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\">&#91;5&#93;</a></sup> \n</p><p>During the <a href=\"/index.php/Battle_of_the_Kingsroad\" title=\"Battle of the Kingsroad\">Battle of the Kingsroad</a> in <a href=\"/index.php/131_AC\" title=\"131 AC\">131&#160;AC</a>, Benjicot led the army with his liege, <a href=\"/index.php/Kermit_Tully\" title=\"Kermit Tully\">Kermit Tully</a>, <a href=\"/index.php/Lord_of_Riverrun\" title=\"Lord of Riverrun\">Lord of Riverrun</a>, and Kermit's brother, Ser <a href=\"/index.php/Oscar_Tully\" title=\"Oscar Tully\">Oscar Tully</a>.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-7\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> Benjicot's rivermen broke the flank of Lord <a href=\"/index.php/Borros_Baratheon\" title=\"Borros Baratheon\">Borros Baratheon</a>'s <a href=\"/index.php/Greens\" title=\"Greens\">greens</a> in the battle, allowing the archers of his aunt, <a href=\"/index.php/Alysanne_Blackwood\" title=\"Alysanne Blackwood\">Alysanne</a>, to bring down the green <a href=\"/index.php/Knight\" title=\"Knight\">knights</a>. Benjicot was remembered after the battle as Bloody Ben.<sup id=\"cite_ref-Rtwoiafthe_stormlands:_house_baratheon.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-0\" class=\"reference\"><a href=\"#cite_note-Rtwoiafthe_stormlands:_house_baratheon.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-6\">&#91;6&#93;</a></sup><sup id=\"cite_ref-Rfabthe_dying_of_the_dragons_-_the_short.2C_sad_reign_of_aegon_ii.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_7-0\" class=\"reference\"><a href=\"#cite_note-Rfabthe_dying_of_the_dragons_-_the_short.2C_sad_reign_of_aegon_ii.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-7\">&#91;7&#93;</a></sup>\n</p><p>Benjicot, Kermit, and Oscar became known as \"the <a href=\"/index.php/Lads\" title=\"Lads\">Lads</a>\", a name bestowed upon them by their men on account of their youth. Together with Black Aly and Lady <a href=\"/index.php/Sabitha_Frey\" title=\"Sabitha Frey\">Sabitha Frey</a>, they were well received when they arrived at <a href=\"/index.php/King%27s_Landing\" title=\"King&#39;s Landing\">King's Landing</a>. The youths deferred to the more formidable <a href=\"/index.php/Cregan_Stark\" title=\"Cregan Stark\">Cregan Stark</a>, <a href=\"/index.php/Lord_of_Winterfell\" title=\"Lord of Winterfell\">Lord of Winterfell</a>, after the <a href=\"/index.php/North\" title=\"North\">northern</a> army appeared at the capital, however.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-8\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<h3><span class=\"mw-headline\" id=\"Regency_of_King_Aegon_III\">Regency of King Aegon III</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Benjicot_Blackwood&amp;action=edit&amp;section=4\" class=\"tw-editsection-onhover\" title=\"Edit section: Regency of King Aegon III\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>Lord Blackwood returned to <a href=\"/index.php/Raventree_Hall\" title=\"Raventree Hall\">Raventree Hall</a> after the coronation of King <a href=\"/index.php/Aegon_III_Targaryen\" title=\"Aegon III Targaryen\">Aegon III Targaryen</a> in <a href=\"/index.php/131_AC\" title=\"131 AC\">131&#160;AC</a>. With peace having been achieved, many northmen agreed to settle in the <a href=\"/index.php/Riverlands\" title=\"Riverlands\">riverlands</a> instead of returning to the <a href=\"/index.php/North\" title=\"North\">north</a>, and <a href=\"/index.php/Widow_Fairs\" title=\"Widow Fairs\">Widow Fairs</a> were held at Raventree and other river castles.<sup id=\"cite_ref-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_8-0\" class=\"reference\"><a href=\"#cite_note-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-8\">&#91;8&#93;</a></sup> The following year, Ben took the <a href=\"/index.php/Kingsroad\" title=\"Kingsroad\">kingsroad</a> to <a href=\"/index.php/Winterfell\" title=\"Winterfell\">Winterfell</a> to attend the winter wedding of his aunt, <a href=\"/index.php/Alysanne_Blackwood\" title=\"Alysanne Blackwood\">Alysanne Blackwood</a>, to Lord <a href=\"/index.php/Cregan_Stark\" title=\"Cregan Stark\">Cregan Stark</a>. Ben's retinue was attacked three times en route by outlaws, however, and his wedding gifts were stolen.<sup id=\"cite_ref-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_8-1\" class=\"reference\"><a href=\"#cite_note-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-8\">&#91;8&#93;</a></sup>\n</p><p>When Lord <a href=\"/index.php/Unwin_Peake\" title=\"Unwin Peake\">Unwin Peake</a> planned for Aegon to wed his daughter, <a href=\"/index.php/Myrielle_Peake\" title=\"Myrielle Peake\">Myrielle Peake</a>, after the death of Queen <a href=\"/index.php/Jaehaera_Targaryen\" title=\"Jaehaera Targaryen\">Jaehaera Targaryen</a>, Lord Blackwood and other lords questioned Unwin's hastiness. Instead, the <a href=\"/index.php/Maiden%27s_Day_Ball\" title=\"Maiden&#39;s Day Ball\">Maiden's Day Ball</a> was held in <a href=\"/index.php/133_AC\" title=\"133 AC\">133&#160;AC</a>, and Aegon wed <a href=\"/index.php/Daenaera_Velaryon\" title=\"Daenaera Velaryon\">Daenaera Velaryon</a>.<sup id=\"cite_ref-Rfabunder_the_regents_-_war_and_peace_and_cattle_shows.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_9-0\" class=\"reference\"><a href=\"#cite_note-Rfabunder_the_regents_-_war_and_peace_and_cattle_shows.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-9\">&#91;9&#93;</a></sup>\n</p><p>In <a href=\"/index.php/135_AC\" title=\"135 AC\">135&#160;AC</a>, Benjicot and a thousand Blackwood men supported Ser <a href=\"/index.php/Robert_Rowan\" title=\"Robert Rowan\">Robert Rowan</a>'s campaign to end the <a href=\"/index.php/Arryn_succession_conflict_(134_AC)\" title=\"Arryn succession conflict (134 AC)\">succession conflict</a> in the <a href=\"/index.php/Vale_of_Arryn\" title=\"Vale of Arryn\">Vale of Arryn</a>. Robert's host of nine thousand was slowed by snow on the <a href=\"/index.php/High_road\" title=\"High road\">high road</a>, however, and repeatedly attacked by desperate <a href=\"/index.php/Vale_mountain_clans\" title=\"Vale mountain clans\">Vale mountain clansmen</a>. After Robert was crushed by a boulder, the young but experienced Benjicot took command. The royal host had lost a third of their men in reaching the <a href=\"/index.php/Bloody_Gate\" title=\"Bloody Gate\">Bloody Gate</a>, and were therefore less useful for the cause of Ser <a href=\"/index.php/Joffrey_Arryn\" title=\"Joffrey Arryn\">Joffrey Arryn</a>.<sup id=\"cite_ref-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_8-2\" class=\"reference\"><a href=\"#cite_note-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-8\">&#91;8&#93;</a></sup> Benjicot and Lord <a href=\"/index.php/Alyn_Velaryon\" title=\"Alyn Velaryon\">Alyn Velaryon</a> eventually forced the other claimants to accept Joffrey, and Benjicot returned to Raventree.<sup id=\"cite_ref-Rfabthe_lysene_spring_and_the_end_of_regency.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_10-0\" class=\"reference\"><a href=\"#cite_note-Rfabthe_lysene_spring_and_the_end_of_regency.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-10\">&#91;10&#93;</a></sup>\n</p>\n<h3><span class=\"mw-headline\" id=\"Later_life\">Later life</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Benjicot_Blackwood&amp;action=edit&amp;section=5\" class=\"tw-editsection-onhover\" title=\"Edit section: Later life\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>Benjicot had a long life.<sup id=\"cite_ref-Rfabthe_dying_of_the_dragons_-_the_short.2C_sad_reign_of_aegon_ii.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_7-1\" class=\"reference\"><a href=\"#cite_note-Rfabthe_dying_of_the_dragons_-_the_short.2C_sad_reign_of_aegon_ii.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-7\">&#91;7&#93;</a></sup> In <a href=\"/index.php/Years_after_Aegon%27s_Conquest#Year_138_After_the_Conquest\" title=\"Years after Aegon&#39;s Conquest\">138&#160;AC</a>, he allowed Lord <a href=\"/index.php/Alyn_Velaryon\" title=\"Alyn Velaryon\">Alyn Velaryon</a> to bring the bones of his brother <a href=\"/index.php/Addam_Velaryon\" title=\"Addam Velaryon\">Addam</a>, which had been taken to <a href=\"/index.php/Raventree_Hall\" title=\"Raventree Hall\">Raventree Hall</a> after <a href=\"/index.php/Second_Battle_of_Tumbleton\" title=\"Second Battle of Tumbleton\">Second Tumbleton</a> in <a href=\"/index.php/130_AC\" title=\"130 AC\">130&#160;AC</a>, to <a href=\"/index.php/Driftmark\" title=\"Driftmark\">Driftmark</a> so they could be entombed in <a href=\"/index.php/Hull\" title=\"Hull\">Hull</a>.<sup id=\"cite_ref-Rfabthe_dying_of_the_dragons_-_rhaenyra_overthrown.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-1\" class=\"reference\"><a href=\"#cite_note-Rfabthe_dying_of_the_dragons_-_rhaenyra_overthrown.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\">&#91;5&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Family\">Family</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Benjicot_Blackwood&amp;action=edit&amp;section=6\" class=\"tw-editsection-onhover\" title=\"Edit section: Family\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div style=\"overflow:auto;\"><table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"border-collapse:separate;font: 90% sans-serif;\">\n<tbody><tr align=\"center\"><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\">Lord<br /><a href=\"/index.php/House_Blackwood\" title=\"House Blackwood\">Blackwood</a></td><td colspan=\"2\" style=\"border-bottom:1px solid black\"><div style=\"width:2em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\">Unknown<br />wife</td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td></tr><tr align=\"center\"><td style=\"border-right:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td></tr>\n<tr align=\"center\"><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td><div style=\"width:1em; height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td style=\"border-bottom:1px solid black\"><div style=\"width:1em; height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"2\" style=\"border-bottom:1px solid black;\"><div style=\"width:2em;height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"2\" style=\"border-bottom:1px solid black;\"><div style=\"width:2em;height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"2\" style=\"border-bottom:1px solid black;\"><div style=\"width:2em;height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td style=\"border-right:1px solid black;border-bottom:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td style=\"border-bottom:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"2\" style=\"border-bottom:1px solid black;\"><div style=\"width:2em;height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"2\" style=\"border-bottom:1px solid black;\"><div style=\"width:2em;height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"2\" style=\"border-bottom:1px solid black;\"><div style=\"width:2em;height:1em;\"><span style=\"font:1px/1px s