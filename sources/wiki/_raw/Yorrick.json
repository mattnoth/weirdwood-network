  "html": "<div class=\"mw-parser-output\"><table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;font-weight:bold; background: none; line-height: 1.1em;\"><table style=\"width:100%\"><tbody><tr><td style=\"border:none;vertical-align:top;text-align:left;width:50px\"><a href=\"/index.php/Maesters\" title=\"Maesters\"><img alt=\"Maester.svg\" src=\"/images/thumb/4/46/Maester.svg/50px-Maester.svg.png\" width=\"50\" height=\"50\" srcset=\"/images/thumb/4/46/Maester.svg/75px-Maester.svg.png 1.5x, /images/thumb/4/46/Maester.svg/100px-Maester.svg.png 2x\" /></a></td><td style=\"border:none;vertical-align:middle;text-align:center;padding:0px 7px 5px 7px\"><span style=\"font-size:80%;font-weight:normal\"> Maester</span><br />Yorrick</td><td style=\"border:none;vertical-align:top;text-align:right;width:50px\"><a href=\"/index.php/Maesters\" title=\"Maesters\"><img alt=\"Maester.svg\" src=\"/images/thumb/4/46/Maester.svg/50px-Maester.svg.png\" width=\"50\" height=\"50\" srcset=\"/images/thumb/4/46/Maester.svg/75px-Maester.svg.png 1.5x, /images/thumb/4/46/Maester.svg/100px-Maester.svg.png 2x\" /></a></td></tr></tbody></table></th></tr><tr><td colspan=\"2\" style=\"text-align:center\"></td></tr><tr><th scope=\"row\">Title</th><td>\n<a href=\"/index.php/Maester\" class=\"mw-redirect\" title=\"Maester\">Maester</a> at <a href=\"/index.php/New_Castle\" title=\"New Castle\">New Castle</a></td></tr><tr><th scope=\"row\">Allegiances</th><td>\n<div class=\"plainlist\"><ul><li>The <a href=\"/index.php/Citadel\" title=\"Citadel\">Citadel</a></li><li><a href=\"/index.php/House_Manderly\" title=\"House Manderly\">House Manderly</a></li></ul></div></td></tr><tr><th scope=\"row\">Book</th><td>\n<i><a href=\"/index.php/The_World_of_Ice_%26_Fire\" title=\"The World of Ice &amp; Fire\">The World of Ice &amp; Fire</a></i> (mentioned)</td></tr></tbody></tabl