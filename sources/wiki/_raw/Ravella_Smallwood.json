{
  "page": "Ravella Smallwood",
  "html": "<div class=\"mw-parser-output\"><table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;font-weight:bold; background: none; line-height: 1.1em;\"><table style=\"width:100%\"><tbody><tr><td style=\"border:none;vertical-align:top;text-align:left;width:50px\"><a href=\"/index.php/House_Swann\" title=\"House Swann\"><img alt=\"House Swann.svg\" src=\"/images/thumb/9/94/House_Swann.svg/50px-House_Swann.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/9/94/House_Swann.svg/75px-House_Swann.svg.png 1.5x, /images/thumb/9/94/House_Swann.svg/100px-House_Swann.svg.png 2x\" /></a></td><td style=\"border:none;vertical-align:middle;text-align:center;padding:0px 7px 5px 7px\"><span style=\"font-size:80%;font-weight:normal\"> Lady</span><br />Ravella Smallwood</td><td style=\"border:none;vertical-align:top;text-align:right;width:50px\"><a href=\"/index.php/House_Smallwood\" title=\"House Smallwood\"><img alt=\"House Smallwood.svg\" src=\"/images/thumb/8/80/House_Smallwood.svg/50px-House_Smallwood.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/8/80/House_Smallwood.svg/75px-House_Smallwood.svg.png 1.5x, /images/thumb/8/80/House_Smallwood.svg/100px-House_Smallwood.svg.png 2x\" /></a></td></tr></tbody></table></th></tr><tr><td colspan=\"2\" class=\"infobox-image\" style=\"text-align:center\">\n<a href=\"/index.php/File:Ravella_Smallwood_and_Arya_Stark_by_Amuelia.png\" class=\"image\"><img alt=\"Ravella Smallwood and Arya Stark by Amuelia.png\" src=\"/images/thumb/2/2b/Ravella_Smallwood_and_Arya_Stark_by_Amuelia.png/350px-Ravella_Smallwood_and_Arya_Stark_by_Amuelia.png\" width=\"350\" height=\"470\" srcset=\"/images/2/2b/Ravella_Smallwood_and_Arya_Stark_by_Amuelia.png 1.5x\" /></a><div>Ravella and <a href=\"/index.php/Arya_Stark\" title=\"Arya Stark\">Arya Stark</a> by Amuelia</div></td></tr><tr><td colspan=\"2\" style=\"text-align:center\">\n<hr /></td></tr><tr><th scope=\"row\">Alias</th><td>\nRavella Swann</td></tr><tr><th scope=\"row\">Title</th><td>\nLady of <a href=\"/index.php/Acorn_Hall\" title=\"Acorn Hall\">Acorn Hall</a></td></tr><tr><th scope=\"row\">Allegiances</th><td>\n<div class=\"plainlist\"><ul><li><a href=\"/index.php/House_Swann\" title=\"House Swann\">House Swann</a></li><li><a href=\"/index.php/House_Smallwood\" title=\"House Smallwood\">House Smallwood</a></li></ul></div></td></tr><tr><th scope=\"row\">Culture</th><td>\n<a href=\"/index.php/Dornish_marches\" class=\"mw-redirect\" title=\"Dornish marches\">Marcher</a></td></tr><tr><th scope=\"row\">Spouse</th><td>\nLord <a href=\"/index.php/Theomar_Smallwood\" title=\"Theomar Smallwood\">Theomar Smallwood</a></td></tr><tr><th scope=\"row\">Lover</th><td>\n<a href=\"/index.php/Tom_of_Sevenstreams\" title=\"Tom of Sevenstreams\">Tom of Sevenstreams</a> <small>(formerly)</small></td></tr><tr><th scope=\"row\">Issue</th><td>\n<div class=\"plainlist\"><ul><li><a href=\"/index.php/Carellen_Smallwood\" title=\"Carellen Smallwood\">Carellen Smallwood</a></li><li>Deceased son</li></ul></div></td></tr><tr><th scope=\"row\">Books</th><td>\n<div class=\"plainlist\"><ul><li><i><a href=\"/index.php/A_Storm_of_Swords\" title=\"A Storm of Swords\">A Storm of Swords</a></i> (appears)</li><li><i><a href=\"/index.php/A_Feast_for_Crows\" title=\"A Feast for Crows\">A Feast for Crows</a></i> (mentioned)</li></ul></div></td></tr></tbody></table>\n<p><b>Ravella Smallwood</b>,<sup id=\"cite_ref-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-0\" class=\"reference\"><a href=\"#cite_note-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> née <b>Swann</b>,<sup id=\"cite_ref-Raffcappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\" class=\"reference\"><a href=\"#cite_note-Raffcappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup> is the Lady of <a href=\"/index.php/Acorn_Hall\" title=\"Acorn Hall\">Acorn Hall</a>. She is the wife of Lord <a href=\"/index.php/Theomar_Smallwood\" title=\"Theomar Smallwood\">Theomar Smallwood</a> and the mother of <a href=\"/index.php/Carellen_Smallwood\" title=\"Carellen Smallwood\">Carellen Smallwood</a>.<sup id=\"cite_ref-Rasosappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-0\" class=\"reference\"><a href=\"#cite_note-Rasosappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup>\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\" lang=\"en\" dir=\"ltr\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Character\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Character</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#History\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">History</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#Recent_Events\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Recent Events</span></a>\n<ul>\n<li class=\"toclevel-2 tocsection-4\"><a href=\"#A_Storm_of_Swords\"><span class=\"tocnumber\">3.1</span> <span class=\"toctext\"><i>A Storm of Swords</i></span></a></li>\n</ul>\n</li>\n<li class=\"toclevel-1 tocsection-5\"><a href=\"#Family\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">Family</span></a></li>\n<li class=\"toclevel-1 tocsection-6\"><a href=\"#Quotes\"><span class=\"tocnumber\">5</span> <span class=\"toctext\">Quotes</span></a></li>\n<li class=\"toclevel-1 tocsection-7\"><a href=\"#References\"><span class=\"tocnumber\">6</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h2><span class=\"mw-headline\" id=\"Character\">Character</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ravella_Smallwood&amp;action=edit&amp;section=1\" class=\"tw-editsection-onhover\" title=\"Edit section: Character\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>Ravella is kind and welcoming, but also has a temper and a sharp tongue, as well as a scornful look towards those that have displeased her.<sup id=\"cite_ref-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-1\" class=\"reference\"><a href=\"#cite_note-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"History\">History</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ravella_Smallwood&amp;action=edit&amp;section=2\" class=\"tw-editsection-onhover\" title=\"Edit section: History\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>Ravella had a son who died when he was seven. According to <a href=\"/index.php/Anguy\" title=\"Anguy\">Anguy</a>, Ravella and <a href=\"/index.php/Tom_of_Sevenstreams\" title=\"Tom of Sevenstreams\">Tom of Sevenstreams</a> were once lovers. According to Tom, Ravella enjoyed his playing of the song \"<a href=\"/index.php/Let_Me_Drink_Your_Beauty\" title=\"Let Me Drink Your Beauty\">Let Me Drink Your Beauty</a>\".<sup id=\"cite_ref-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-2\" class=\"reference\"><a href=\"#cite_note-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Recent_Events\">Recent Events</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ravella_Smallwood&amp;action=edit&amp;section=3\" class=\"tw-editsection-onhover\" title=\"Edit section: Recent Events\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span class=\"mw-headline\" id=\"A_Storm_of_Swords\"><i>A Storm of Swords</i></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ravella_Smallwood&amp;action=edit&amp;section=4\" class=\"tw-editsection-onhover\" title=\"Edit section: A Storm of Swords\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>At the start of the <a href=\"/index.php/War_of_the_Five_Kings\" title=\"War of the Five Kings\">War of the Five Kings</a>, Lady Smallwood sends her daughter, <a href=\"/index.php/Carellen_Smallwood\" title=\"Carellen Smallwood\">Carellen</a>, to a <a href=\"/index.php/Motherhouse\" title=\"Motherhouse\">motherhouse</a> in <a href=\"/index.php/Oldtown\" title=\"Oldtown\">Oldtown</a>, where Ravella's great-aunt is a <a href=\"/index.php/Septa\" title=\"Septa\">septa</a>.<sup id=\"cite_ref-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-3\" class=\"reference\"><a href=\"#cite_note-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p><p><a href=\"/index.php/Beric_Dondarrion\" title=\"Beric Dondarrion\">Beric Dondarrion</a> and <a href=\"/index.php/Thoros_of_Myr\" class=\"mw-redirect\" title=\"Thoros of Myr\">Thoros of Myr</a> visit <a href=\"/index.php/Acorn_Hall\" title=\"Acorn Hall\">Acorn Hall</a> with a dozen of the <a href=\"/index.php/Brotherhood_without_banners\" title=\"Brotherhood without banners\">brotherhood without banners</a>, herding a flock of sheep. In return for Lady Smallwood's hospitality, Thoros gives her three sheep.<sup id=\"cite_ref-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-4\" class=\"reference\"><a href=\"#cite_note-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p><p><a href=\"/index.php/Northmen\" title=\"Northmen\">Northmen</a> wearing the <a href=\"/index.php/Heraldry\" title=\"Heraldry\">heraldry</a> of <a href=\"/index.php/House_Karstark\" title=\"House Karstark\">House Karstark</a> come to Acorn Hall's gates to see if the Smallwoods are harboring the escaped <a href=\"/index.php/Jaime_Lannister\" title=\"Jaime Lannister\">Jaime Lannister</a>. Lady Ravella claims to them she had made love to Jaime until he was too exhausted to move, and when the Karstark men call her a liar, she has them sent off by having her men shoot arrows at them.<sup id=\"cite_ref-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-5\" class=\"reference\"><a href=\"#cite_note-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p><p>When <a href=\"/index.php/Arya_Stark\" title=\"Arya Stark\">Arya Stark</a> and the <a href=\"/index.php/Brotherhood_without_banners\" title=\"Brotherhood without banners\">brotherhood without banners</a> come to <a href=\"/index.php/Acorn_Hall\" title=\"Acorn Hall\">Acorn Hall</a>, Lady Ravella welcomes the <a href=\"/index.php/Outlaw\" class=\"mw-redirect\" title=\"Outlaw\">outlaws</a>, but becomes angry that they brought a young girl through a warzone. After she learns that Arya is <a href=\"/index.php/Highborn\" class=\"mw-redirect\" title=\"Highborn\">highborn</a>, Lady Smallwood insists that she take a bath and be dressed as a proper lady, giving her one of her daughter's dresses, green with embroidered acorns. Lady Smallwood gives the brotherhood information concerning the whereabouts of Lord <a href=\"/index.php/Beric_Dondarrion\" title=\"Beric Dondarrion\">Beric Dondarrion</a>. She also relays the news that Jaime Lannister had escaped <a href=\"/index.php/Riverrun\" title=\"Riverrun\">Riverrun</a>, allegedly set free by <a href=\"/index.php/Catelyn_Stark\" title=\"Catelyn Stark\">Catelyn Stark</a>, which upsets Arya to hear. After Arya tears her dress while scuffling with <a href=\"/index.php/Gendry\" title=\"Gendry\">Gendry</a>, Lady Smallwood has her washed again and put in another of Carellen's dresses, lilac with baby <a href=\"/index.php/Pearl\" title=\"Pearl\">pearls</a>. However, the dress is too delicate to ride in, so when Arya and the brotherhood leave Acorn Hall the next morning, Lady Smallwood gives her boy's clothing to wear, which had belonged to her late son.<sup id=\"cite_ref-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-6\" class=\"reference\"><a href=\"#cite_note-Rasos22.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p><p>When Arya worries that her brother, King <a href=\"/index.php/Robb_Stark\" title=\"Robb Stark\">Robb Stark</a>, will not pay the brotherhood a ransom for her, Beric Dondarrion tells her if that is so, he will send her to the protection of Lady Smallwood.<sup id=\"cite_ref-Rasos39.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-0\" class=\"reference\"><a href=\"#cite_note-Rasos39.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\">&#91;4&#93;</a></sup>\n</p><p>When <a href=\"/index.php/Sandor_Clegane\" title=\"Sandor Clegane\">Sandor Clegane</a> and Arya approach <a href=\"/index.php/The_Twins\" class=\"mw-redirect\" title=\"The Twins\">the Twins</a> for the <a href=\"/index.php/Red_Wedding\" title=\"Red Wedding\">wedding</a> of <a href=\"/index.php/Edmure_Tully\" title=\"Edmure Tully\">Edmure Tully</a> and <a href=\"/index.php/Roslin_Frey\" title=\"Roslin Frey\">Roslin Frey</a>, Arya recognizes <a href=\"/index.php/Theomar_Smallwood\" title=\"Theomar Smallwood\">Lord Smallwoood</a>'s pavilion by its acorn <a href=\"/index.php/Sigil\" class=\"mw-redirect\" title=\"Sigil\">sigil</a> and is reminded of Lady Smallwood.<sup id=\"cite_ref-Rasos50.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-0\" class=\"reference\"><a href=\"#cite_note-Rasos50.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\">&#91;5&#93;</a></sup>\n</p><p>In a village in the foothills of the <a href=\"/index.php/Mountains_of_the_Moon\" title=\"Mountains of the Moon\">Mountains of the Moon</a>, some of the women try to make Arya wear a dress and do needlework, but as they are not Lady Smallwood, she refuses them.<sup id=\"cite_ref-Rasos65.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-0\" class=\"reference\"><a href=\"#cite_note-Rasos65.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-6\">&#91;6&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Family\">Family</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ravella_Smallwood&amp;action=edit&amp;section=5\" class=\"tw-editsection-onhover\" title=\"Edit section: Family\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div style=\"overflow:auto;\"><table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"border-collapse:separate;font: 90% sans-serif;\">\n<tbody><tr align=\"center\"><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\"><a href=\"/index.php/Gulian_Swann\" title=\"Gulian Swann\">Gulian</a></td><td colspan=\"2\" style=\"border-bottom:1px solid black\"><div style=\"width:2em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\">Unknown<br />wife</td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\"><a href=\"/index.php/Walder_Frey\" title=\"Walder Frey\">Walder<br />Frey</a></td><td colspan=\"2\" style=\"border-bottom:1px solid black\"><div style=\"width:2em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\"><a href=\"/index.php/Cyrenna_Swann\" title=\"Cyrenna Swann\">Cyrenna</a></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px so