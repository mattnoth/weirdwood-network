</tr><tr><td colspan=\"2\" style=\"text-align:center\">\n<table style=\"width:100%; text-align:left;\">\n<tbody><tr><td colspan=\"2\" style=\"background-color: #B0C4DE; text-align: center;\"><b>Combatants</b></td></tr><tr><td width=\"50%\" style=\"border-right:1px dotted #aaa;\"><a href=\"/index.php/File:House_Targaryen.svg\" class=\"image\"><img alt=\"House Targaryen.svg\" src=\"/images/thumb/1/1e/House_Targaryen.svg/30px-House_Targaryen.svg.png\" width=\"30\" height=\"33\" srcset=\"/images/thumb/1/1e/House_Targaryen.svg/45px-House_Targaryen.svg.png 1.5x, /images/thumb/1/1e/House_Targaryen.svg/60px-House_Targaryen.svg.png 2x\" /></a> <b><a href=\"/index.php/House_Targaryen\" title=\"House Targaryen\">House Targaryen</a></b>\n<ul><li><a href=\"/index.php/File:House_Mooton.svg\" class=\"image\"><img alt=\"House Mooton.svg\" src=\"/images/thumb/a/a6/House_Mooton.svg/20px-House_Mooton.svg.png\" width=\"20\" height=\"22\" srcset=\"/images/thumb/a/a6/House_Mooton.svg/30px-House_Mooton.svg.png 1.5x, /images/thumb/a/a6/House_Mooton.svg/40px-House_Mooton.svg.png 2x\" /></a>  <a href=\"/index.php/House_Mooton\" title=\"House Mooton\">House Mooton</a></li></ul></td>\n    <td width=\"50%\"><a href=\"/index.php/File:House_Lannister.svg\" class=\"image\"><img alt=\"House Lannister.svg\" src=\"/images/thumb/d/d5/House_Lannister.svg/30px-House_Lannister.svg.png\" width=\"30\" height=\"33\" srcset=\"/images/thumb/d/d5/House_Lannister.svg/45px-House_Lannister.svg.png 1.5x, /images/thumb/d/d5/House_Lannister.svg/60px-House_Lannister.svg.png 2x\" /></a> <b><a href=\"/index.php/Kingdom_of_the_Rock\" class=\"mw-redirect\" title=\"Kingdom of the Rock\">Kingdom of the Rock</a></b>/<a href=\"/index.php/House_Lannister\" title=\"House Lannister\">House Lannister</a>:\n<p><a href=\"/index.php/File:House_Gardener.svg\" class=\"image\"><img alt=\"House Gardener.svg\" src=\"/images/thumb/f/f2/House_Gardener.svg/30px-House_Gardener.svg.png\" width=\"30\" height=\"33\" srcset=\"/images/thumb/f/f2