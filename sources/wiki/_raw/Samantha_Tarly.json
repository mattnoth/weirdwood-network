  "html": "<div class=\"mw-parser-output\"><table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;font-weight:bold; background: none; line-height: 1.1em;\"><table style=\"width:100%\"><tbody><tr><td style=\"border:none;vertical-align:top;text-align:left;width:50px\"><a href=\"/index.php/House_Tarly\" title=\"House Tarly\"><img alt=\"House Tarly.svg\" src=\"/images/thumb/c/cc/House_Tarly.svg/50px-House_Tarly.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/c/cc/House_Tarly.svg/75px-House_Tarly.svg.png 1.5x, /images/thumb/c/cc/House_Tarly.svg/100px-House_Tarly.svg.png 2x\" /></a></td><td style=\"border:none;vertical-align:middle;text-align:center;padding:0px 7px 5px 7px\"><span style=\"font-size:80%;font-weight:normal\"> Lady</span><br />Samantha Tarly</td><td style=\"border:none;vertical-align:top;text-align:right;width:50px\"><a href=\"/index.php/House_Hightower\" title=\"House Hightower\"><img alt=\"House Hightower.svg\" src=\"/images/thumb/f/fe/House_Hightower.svg/50px-House_Hightower.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/f/fe/House_Hightower.svg/75px-House_Hightower.svg.png 1.5x, /images/thumb/f/fe/House_Hightower.svg/100px-House_Hightower.svg.png 2x\" /></a></td></tr></tbody></table></th></tr><tr><td colspan=\"2\" class=\"infobox-image\" style=\"text-align:center\">\n<a href=\"/index.php/File:The_mistress_of_the_Hightower_by_viscardiac.png\" class=\"image\"><img alt=\"The mistress of the Hightower by viscardiac.png\" src=\"/images/thumb/3/3f/The_mistress_of_the_Hightower_by_viscardiac.png/350px-The_mistress_of_the_Hightower_by_viscardiac.png\" width=\"350\" height=\"467\" srcset=\"/images/thumb/3/3f/The_mistress_of_the_Hightower_by_viscardiac.png/525px-The_mistress_of_the_Hightower_by_viscardiac.png 1.5x, /images/thumb/3/3f/The_mistress_of_the_Hightower_by_viscardiac.png/700px-The_mistress_of_the_Hightower_by_viscardiac.png 2x\" /></a><div>The mistress of the Hightower, by <a rel=\"nofollow\" class=\"external text\" href=\"https://viscardiac.tumblr.com/\">viscardiac</a> ©</div></td></tr><tr><td colspan=\"2\" style=\"text-align:center\">\n<hr /></td></tr><tr><th scope=\"row\">Alias</th><td>\nLady Sam<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-0\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></td></tr><tr><th scope=\"row\">Titles</th><td>\n<div class=\"plainlist\"><ul><li>Lady of <a href=\"/index.php/Oldtown\" title=\"Oldtown\">Oldtown</a><sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-1\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></li><li>Dowager Lady<sup id=\"cite_ref-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\" class=\"reference\"><a href=\"#cite_note-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup></li></ul></div></td></tr><tr><th scope=\"row\">Allegiances</th><td>\n<div class=\"plainlist\"><ul><li><a href=\"/index.php/House_Tarly\" title=\"House Tarly\">House Tarly</a></li><li><a href=\"/index.php/House_Hightower\" title=\"House Hightower\">House Hightower</a></li></ul></div></td></tr><tr><th scope=\"row\">Culture</th><td>\n<a href=\"/index.php/Dornish_Marches\" title=\"Dornish Marches\">Marcher</a></td></tr><tr><th scope=\"row\">Born</th><td>\n<a href=\"/index.php/Years_after_Aegon%27s_Conquest#Year_112_After_the_Conquest\" title=\"Years after Aegon&#39;s Conquest\">112&#160;AC</a> or <a href=\"/index.php/Years_after_Aegon%27s_Conquest#Year_113_After_the_Conquest\" title=\"Years after Aegon&#39;s Conquest\">113&#160;AC</a><sup id=\"cite_ref-ages_3-0\" class=\"reference\"><a href=\"#cite_note-ages-3\">&#91;3&#93;</a></sup></td></tr><tr><th scope=\"row\">Died</th><td>\n<a href=\"/index.php/Years_after_Aegon%27s_Conquest#Year_143_After_the_Conquest\" title=\"Years after Aegon&#39;s Conquest\">143&#160;AC</a> or after<sup id=\"cite_ref-ages_3-1\" class=\"reference\"><a href=\"#cite_note-ages-3\">&#91;3&#93;</a></sup></td></tr><tr><th scope=\"row\">Father</th><td>\nLord <a href=\"/index.php/Donald_Tarly\" title=\"Donald Tarly\">Donald Tarly</a></td></tr><tr><th scope=\"row\">Mother</th><td>\nLady <a href=\"/index.php/Jeyne_Rowan\" title=\"Jeyne Rowan\">Jeyne Rowan</a></td></tr><tr><th scope=\"row\">Spouses</th><td>\n<div class=\"plainlist\"><ul><li>1<sup>st</sup>: Lord <a href=\"/index.php/Ormund_Hightower\" title=\"Ormund Hightower\">Ormund Hightower</a><sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-2\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></li><li>2<sup>nd</sup>: Lord <a href=\"/index.php/Lyonel_Hightower\" title=\"Lyonel Hightower\">Lyonel Hightower</a><sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-3\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></li></ul></div></td></tr><tr><th scope=\"row\">Issue</th><td>\nSix children<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-4\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></td></tr><tr><th scope=\"row\">Books</th><td>\n<div class=\"plainlist\"><ul><li><i><a href=\"/index.php/Fire_%26_Blood\" title=\"Fire &amp; Blood\">Fire &amp; Blood</a></i> (mentioned)</li><li><i><a href=\"/index.php/The_Rise_of_the_Dragon\" title=\"The Rise of the Dragon\">The Rise of the Dragon</a></i> (mentioned)</li></ul></div></td></tr></tbody></table>\n<p><b>Samantha Tarly</b>, known as <b>Lady Sam</b>, was a member of <a href=\"/index.php/House_Tarly\" title=\"House Tarly\">House Tarly</a> who wed first Lord <a href=\"/index.php/Ormund_Hightower\" title=\"Ormund Hightower\">Ormund Hightower</a> and later his son, Lord <a href=\"/index.php/Lyonel_Hightower\" title=\"Lyonel Hightower\">Lyonel Hightower</a>.  She was the founder of the <a href=\"/index.php/Bank_of_Oldtown\" title=\"Bank of Oldtown\">Bank of Oldtown</a>.<sup id=\"cite_ref-Rfabthe_lysene_spring_and_the_end_of_regency.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-0\" class=\"reference\"><a href=\"#cite_note-Rfabthe_lysene_spring_and_the_end_of_regency.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\">&#91;4&#93;</a></sup>\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\" lang=\"en\" dir=\"ltr\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Appearance_and_Character\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Appearance and Character</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#History\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">History</span></a>\n<ul>\n<li class=\"toclevel-2 tocsection-3\"><a href=\"#Dance_of_the_Dragons\"><span class=\"tocnumber\">2.1</span> <span class=\"toctext\">Dance of the Dragons</span></a></li>\n<li class=\"toclevel-2 tocsection-4\"><a href=\"#Regency_of_Aegon_III\"><span class=\"tocnumber\">2.2</span> <span class=\"toctext\">Regency of Aegon III</span></a></li>\n<li class=\"toclevel-2 tocsection-5\"><a href=\"#Later_Life\"><span class=\"tocnumber\">2.3</span> <span class=\"toctext\">Later Life</span></a></li>\n</ul>\n</li>\n<li class=\"toclevel-1 tocsection-6\"><a href=\"#Family\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Family</span></a></li>\n<li class=\"toclevel-1 tocsection-7\"><a href=\"#References\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h2><span class=\"mw-headline\" id=\"Appearance_and_Character\">Appearance and Character</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Samantha_Tarly&amp;action=edit&amp;section=1\" class=\"tw-editsection-onhover\" title=\"Edit section: Appearance and Character\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>Archmaester <a href=\"/index.php/Gyldayn\" title=\"Gyldayn\">Gyldayn</a> describes Samantha as fierce, fiery, and beautiful.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-5\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"History\">History</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Samantha_Tarly&amp;action=edit&amp;section=2\" class=\"tw-editsection-onhover\" title=\"Edit section: History\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span class=\"mw-headline\" id=\"Dance_of_the_Dragons\">Dance of the Dragons</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Samantha_Tarly&amp;action=edit&amp;section=3\" class=\"tw-editsection-onhover\" title=\"Edit section: Dance of the Dragons\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>Samantha was the daughter of <a href=\"/index.php/Donald_Tarly\" title=\"Donald Tarly\">Donald Tarly</a>, <a href=\"/index.php/Lord_of_Horn_Hill\" title=\"Lord of Horn Hill\">Lord of Horn Hill</a>, and Lady <a href=\"/index.php/Jeyne_Rowan\" title=\"Jeyne Rowan\">Jeyne Rowan</a>. She was the second wife of Lord <a href=\"/index.php/Ormund_Hightower\" title=\"Ormund Hightower\">Ormund Hightower</a>, head of <a href=\"/index.php/House_Hightower\" title=\"House Hightower\">House Hightower</a> and a supporter of the <a href=\"/index.php/Greens\" title=\"Greens\">greens</a> during the <a href=\"/index.php/Dance_of_the_Dragons\" title=\"Dance of the Dragons\">Dance of the Dragons</a>.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-6\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p><p>Ormund, <a href=\"/index.php/Lord_of_the_Hightower\" title=\"Lord of the Hightower\">Lord of the Hightower</a>, died at the <a href=\"/index.php/First_Battle_of_Tumbleton\" title=\"First Battle of Tumbleton\">First Battle of Tumbleton</a> in <a href=\"/index.php/130_AC\" title=\"130 AC\">130&#160;AC</a>. According to <a href=\"/index.php/Mushroom\" title=\"Mushroom\">Mushroom</a>, the fifteen-year-old Lord <a href=\"/index.php/Lyonel_Hightower\" title=\"Lyonel Hightower\">Lyonel Hightower</a> was infatuated with his father's widow, who was only two years older than the young lord, but Samantha refused his advances.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-7\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> <a href=\"/index.php/House_Hightower\" title=\"House Hightower\">House Hightower</a> declined King <a href=\"/index.php/Aegon_II_Targaryen\" title=\"Aegon II Targaryen\">Aegon II Targaryen</a>'s demand for new armies after the <a href=\"/index.php/Moon_of_the_Three_Kings\" title=\"Moon of the Three Kings\">Moon of the Three Kings</a>.<sup id=\"cite_ref-Rfabthe_dying_of_the_dragons_-_the_short.2C_sad_reign_of_aegon_ii.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-0\" class=\"reference\"><a href=\"#cite_note-Rfabthe_dying_of_the_dragons_-_the_short.2C_sad_reign_of_aegon_ii.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\">&#91;5&#93;</a></sup>\n</p><p>During the <a href=\"/index.php/False_Dawn\" class=\"mw-redirect\" title=\"False Dawn\">False Dawn</a>, Lord <a href=\"/index.php/Corlys_Velaryon\" title=\"Corlys Velaryon\">Corlys Velaryon</a> attempted to make peace between the warring factions. Lord Lyonel initially reacted angrily to the Sea Snake's offer, but Samantha allegedly persuaded her step-son to agree to Corlys's terms by allowing Lyonel to seduce her and promising to marry him if he made peace. Sam was related to the <a href=\"/index.php/House_Tarly\" title=\"House Tarly\">Tarlys</a> and <a href=\"/index.php/House_Rowan\" title=\"House Rowan\">Rowans</a>, houses who supported the <a href=\"/index.php/Blacks\" title=\"Blacks\">blacks</a> of Queen <a href=\"/index.php/Rhaenyra_Targaryen\" title=\"Rhaenyra Targaryen\">Rhaenyra Targaryen</a>. Grand Maester <a href=\"/index.php/Munkun\" title=\"Munkun\">Munkun</a> believes that Lord Hightower accepted the terms because of the end to <a href=\"/index.php/House_Tyrell\" title=\"House Tyrell\">Tyrell</a> neutrality, however.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-8\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<h3><span class=\"mw-headline\" id=\"Regency_of_Aegon_III\">Regency of Aegon III</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Samantha_Tarly&amp;action=edit&amp;section=4\" class=\"tw-editsection-onhover\" title=\"Edit section: Regency of Aegon III\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:352px;\"><a href=\"/index.php/File:Samantha_Tarly_by_lilith_kruger.jpg\" class=\"image\"><img alt=\"\" src=\"/images/thumb/3/3e/Samantha_Tarly_by_lilith_kruger.jpg/350px-Samantha_Tarly_by_lilith_kruger.jpg\" width=\"350\" height=\"477\" class=\"thumbimage\" srcset=\"/images/thumb/3/3e/Samantha_Tarly_by_lilith_kruger.jpg/525px-Samantha_Tarly_by_lilith_kruger.jpg 1.5x, /images/thumb/3/3e/Samantha_Tarly_by_lilith_kruger.jpg/700px-Samantha_Tarly_by_lilith_kruger.jpg 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/index.php/File:Samantha_Tarly_by_lilith_kruger.jpg\" class=\"internal\" title=\"Enlarge\"></a></div>Samantha Tarly, by lilith-kruger ©</div></div></div>\n<p>Lord Lyonel announced his intention to marry his father's widow, but the reigning <a href=\"/index.php/High_Septon_(Regency_of_Aegon_III)\" title=\"High Septon (Regency of Aegon III)\">High Septon</a> forbade the union as a form of <a href=\"/index.php/Incest\" title=\"Incest\">incest</a>. However, Lyonel kept Samantha as his <a href=\"/index.php/Paramour\" title=\"Paramour\">paramour</a> for thirteen years and fathered six children on her.<sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-9\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> Lyonel and Lady Sam attended the coronation of King <a href=\"/index.php/Aegon_III_Targaryen\" title=\"Aegon III Targaryen\">Aegon III Targaryen</a> and <a href=\"/index.php/Wedding_of_Aegon_III_Targaryen_and_Jaehaera_Targaryen\" title=\"Wedding of Aegon III Targaryen and Jaehaera Targaryen\">his wedding</a> to Queen <a href=\"/index.php/Jaehaera_Targaryen\" title=\"Jaehaera Targaryen\">Jaehaera Targaryen</a>, with their presence being so great a scandal that the High Septon refused to travel with them.<sup id=\"cite_ref-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-1\" class=\"reference\"><a href=\"#cite_note-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>Relations between the Hightowers and the <a href=\"/index.php/Faith_of_the_Seven\" title=\"Faith of the Seven\">Faith of the Seven</a> soured when the High Septon commanded Lady Sam to remove herself from her step-son's bed and take vows as a <a href=\"/index.php/Silent_sisters\" title=\"Silent sisters\">silent sister</a> as penance. When she refused, the High Septon condemned her as a shameless fornicator and forbade her to set foot in the <a href=\"/index.php/Starry_Sept\" title=\"Starry Sept\">Starry Sept</a> until she repented. Instead, Samantha mounted a warhorse and burst into the Starry Sept as the High Septon was leading prayer, claiming that while she could not set foot there, the High Septon had said nothing of her horse's hooves. Sam commanded her men to close the doors, as the sept should be closed to all if it was closed for her. Though the High Septon grew furious, he had no choice but to relent.<sup id=\"cite_ref-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-2\" class=\"reference\"><a href=\"#cite_note-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>After the death of Queen Jaehaera in <a href=\"/index.php/133_AC\" title=\"133 AC\">133&#160;AC</a>, Lady Sam wrote a letter proposing that Aegon III take two wives: her sister <a href=\"/index.php/Sansara_Tarly\" title=\"Sansara Tarly\">Sansara</a>, and Lord Lyonel's sister, <a href=\"/index.php/Bethany_Hightower\" title=\"Bethany Hightower\">Bethany</a>. Samantha also appended the names of thirty-one other maidens from Houses <a href=\"/index.php/House_Ambrose\" title=\"House Ambrose\">Ambrose</a>, <a href=\"/index.php/House_Beesbury\" title=\"House Beesbury\">Beesbury</a>, <a href=\"/index.php/House_Cobb\" title=\"House Cobb\">Cobb</a>, <a href=\"/index.php/House_Costayne\" title=\"House Costayne\">Costayne</a>, <a href=\"/index.php/House_Florent\" title=\"House Florent\">Florent</a>, <a href=\"/index.php/House_Grimm\" title=\"House Grimm\">Grimm</a>, <a href=\"/index.php/House_Hightower\" title=\"House Hightower\">Hightower</a>, <a href=\"/index.php/House_Redwyne\" title=\"House Redwyne\">Redwyne</a>, <a href=\"/index.php/House_Tarly\" title=\"House Tarly\">Tarly</a> and <a href=\"/index.php/House_Varner\" title=\"House Varner\">Varner</a> who might be suitable as queens. According to <a href=\"/index.php/Mushroom\" title=\"Mushroom\">Mushroom</a>, Sam offered to suggest the names of boys as well if Aegon were interested, but no other chronicles mention this postscript, and the letter has been lost to history.<sup id=\"cite_ref-Rfabunder_the_regents_-_war_and_peace_and_cattle_shows.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-0\" class=\"reference\"><a href=\"#cite_note-Rfabunder_the_regents_-_war_and_peace_and_cattle_shows.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-6\">&#91;6&#93;</a></sup>\n</p><p>Lyonel and Sam hosted Lord <a href=\"/index.php/Alyn_Velaryon\" title=\"Alyn Velaryon\">Alyn Velaryon</a> when he stopped at <a href=\"/index.php/Oldtown\" title=\"Oldtown\">Oldtown</a> during his voyage toward the <a href=\"/index.php/Iron_Islands\" title=\"Iron Islands\">Iron Islands</a> in <a href=\"/index.php/133_AC\" title=\"133 AC\">133&#160;AC</a>. Alyn became a close friend of the pair due to the courtesy he showed Sam.<sup id=\"cite_ref-Rfabunder_the_regents_-_the_voyage_of_alyn_oakenfist.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_7-0\" class=\"reference\"><a href=\"#cite_note-Rfabunder_the_regents_-_the_voyage_of_alyn_oakenfist.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-7\">&#91;7&#93;</a></sup>\n</p><p>Lady Sam protected <a href=\"/index.php/Lotho_Rogare\" title=\"Lotho Rogare\">Lotho Rogare</a> after the fall of <a href=\"/index.php/House_Rogare\" title=\"House Rogare\">House Rogare</a>. The Hightowers remained extremely wealthy as they had not entrusted any of their gold to <a href=\"/index.php/Lys\" title=\"Lys\">Lys</a> before the <a href=\"/index.php/Rogare_Bank\" title=\"Rogare Bank\">Rogare Bank</a> ran dry. Lotho helped Sam found the prosperous <a href=\"/index.php/Bank_of_Oldtown\" title=\"Bank of Oldtown\">Bank of Oldtown</a>.<sup id=\"cite_ref-Rfabthe_lysene_spring_and_the_end_of_regency.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-1\" class=\"reference\"><a href=\"#cite_note-Rfabthe_lysene_spring_and_the_end_of_regency.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\">&#91;4&#93;</a></sup>\n</p><p>Lord Lyonel and Lady Sam made their way to <a href=\"/index.php/King%27s_Landing\" title=\"King&#39;s Landing\">King's Landing</a> with six hundred men in <a href=\"/index.php/136_AC\" title=\"136 AC\">136&#160;AC</a> when the <a href=\"/index.php/Regency_of_Aegon_III\" title=\"Regency of Aegon III\">new regents</a> were to be chosen by lot.<sup id=\"cite_ref-Rfabthe_lysene_spring_and_the_end_of_regency.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-2\" class=\"reference\"><a href=\"#cite_note-Rfabthe_lysene_spring_and_the_end_of_regency.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\">&#91;4&#93;</a></sup> Lord <a href=\"/index.php/Torrhen_Manderly\" title=\"Torrhen Manderly\">Torrhen Manderly</a> and the regents planned for Aegon III to visit Lyonel and Samantha in Oldtown during a <a href=\"/index.php/Royal_progress\" title=\"Royal progress\">royal progress</a> to mark his coming of age, but the king abruptly cancelled the progress and dismissed his regents.<sup id=\"cite_ref-Rfabthe_lysene_spring_and_the_end_of_regency.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-3\" class=\"reference\"><a href=\"#cite_note-Rfabthe_lysene_spring_and_the_end_of_regency.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\">&#91;4&#93;</a></sup>\n</p>\n<h3><span class=\"mw-headline\" id=\"Later_Life\">Later Life</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Samantha_Tarly&amp;action=edit&amp;section=5\" class=\"tw-editsection-onhover\" title=\"Edit section: Later Life\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>A <a href=\"/index.php/High_Septon_(Aegon_III)\" title=\"High Septon (Aegon III)\">new High Septon</a> eventually reversed the position of his predecessor, allowing Lyonel to marry Sam, and by the same occasion <a href=\"/index.php/Bastardy#Legitimization\" title=\"Bastardy\">legitimized</a> their six chidren.<sup id=\"cite_ref-8\" class=\"reference\"><a href=\"#cite_note-8\">&#91;8&#93;</a></sup><sup id=\"cite_ref-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-10\" class=\"reference\"><a href=\"#cite_note-Rfabaftermath_-_the_hour_of_the_wolf.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p><p>Along with <a href=\"/index.php/Johanna_Lannister\" title=\"Johanna Lannister\">Johanna Lannister</a>, <a href=\"/index.php/Sharis_Footly\" title=\"Sharis Footly\">Sharis Footly</a>, and <a href=\"/index.php/Alys_Rivers\" title=\"Alys Rivers\">Alys Rivers</a>, Samantha is featured in Archmaester <a href=\"/index.php/Abelon\" title=\"Abelon\">Abelon</a>'s <i><a href=\"/index.php/When_Women_Ruled:_Ladies_of_the_Aftermath\" title=\"When Women Ruled: Ladies of the Aftermath\">When Women Ruled: Ladies of the Aftermath</a></i>.<sup id=\"cite_ref-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-3\" class=\"reference\"><a href=\"#cite_note-Rfabunder_the_regents_-_the_hooded_hand.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Family\">Family</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Samantha_Tarly&amp;action=edit&amp;section=6\" class=\"tw-editsection-onhover\" title=\"Edit section: Family\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div style=\"overflow:auto;\"><table cellspacing=\"0\" cellpadding=\"0\" border=\"0\" style=\"border-collapse:separate;font: 90% sans-serif;\">\n<tbody><tr align=\"center\"><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\"><a href=\"/index.php/Donald_Tarly\" title=\"Donald Tarly\">Donald</a></td><td colspan=\"2\" style=\"border-bottom:1px solid black\"><div style=\"width:2em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\"><a href=\"/index.php/Jeyne_Rowan\" title=\"Jeyne Rowan\">Jeyne<br />Rowan</a></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td></tr><tr align=\"center\"><td style=\"border-right:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td></tr>\n<tr align=\"center\"><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan