B4.7D.7D.7D_1-1\" class=\"reference\"><a href=\"#cite_note-Rthk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></td></tr><tr><th scope=\"row\">Culture</th><td>\n<a href=\"/index.php/Rivermen\" title=\"Rivermen\">Rivermen</a><sup id=\"cite_ref-Rthk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-2\" class=\"reference\"><a href=\"#cite_note-Rthk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></td></tr><tr><th scope=\"row\">Born</th><td>\n<a href=\"/index.php/Seagard\" title=\"Seagard\">Seagard</a><sup id=\"cite_ref-Rawoiafjoseth_mallister.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\" class=\"reference\"><a href=\"#cite_note-Rawoiafjoseth_mallister.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup></td></tr><tr><th scope=\"row\">Book</th><td>\n<i><a href=\"/index.php/The_Hedge_Knight\" title=\"The Hedge Knight\">The Hedge Knight</a></i> (appears)</td></tr></tbody></table>\n<p><b>Joseth Mallister</b> was a <a href=\"/index.php/Knight\" title=\"Knight\">knight</a> from <a href=\"/index.php/House_Mallister\" title=\"House Mallister\">House Mallister</a> during the reign of King <a href=\"/index.php/Daeron_II_Targaryen\" title=\"Daeron II Targaryen\">Daeron II Targaryen</a>.<sup id=\"cite_ref-Rthk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-3\" class=\"reference\"><a href=\"#cite_note-Rthk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Appearance\">Appearance</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Joseth_Mallister&amp;action=edit&amp;section=1\" class=\"tw-editsection-onhover\" title=\"Edit section: Appearance\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>Joseth wore a winged helm. His shield bore a <a href=\"/index.php/Silver\" title=\"Silver\">silver</a> <a href=\"/index.php/Eagle\" title=\"Eagle\">eagle</a> flying across an indigo sky, the arms of <a href=\"/index.php/House_Mallister\" title=\"House Mallister\">House Mallister</a>.<sup id=\"cite_ref-Rthk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-4\" class=\"reference\"><a href=\"#cite_note-Rthk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"History\">History</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Joseth_Mallister&amp;action=edit&amp;section=2\" class=\"tw-editsection-onhover\" title=\"Edit section: History\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>In <a href=\"/index.php/209_AC\" title=\"209 AC\">209&#160;AC</a>, Ser Joseth participated in the <a href=\"/index.php/Tourney_at_Ashford_Meadow\" title=\"Tourney at Ashford Meadow\">tourney at Ashford Meadow</a>. He challenged Ser <a href=\"/index.php/Humfrey_Hardyng\" title=\"Humfrey Hardyng\">Humfrey Hardyng</a> in the second tilt, but was defeated and carried from the field unconscious.<sup id=\"cite_ref-Rthk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-5\" class=\"reference\"><a href=\"#cite_note-Rthk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"References\">References</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Joseth_Mallister&amp;action=edit&amp;section=3\" class=\"tw-editsection-onhover\" title=\"Edit section: References\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div class=\"references-small\">\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-Rthk.7B.7B.7B2.7D.7D.7D.7B.7B.7B3.7D.7D.7D.7B.7B.7