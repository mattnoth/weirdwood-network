{
  "page": "Storming of the Crag",
  "html": "<div class=\"mw-parser-output\"><table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;background: #B0C4DE; text-align:center;\">Storming of the Crag</th></tr><tr><th scope=\"row\">Conflict</th><td>\n<a href=\"/index.php/War_of_the_Five_Kings\" title=\"War of the Five Kings\">War of the Five Kings</a></td></tr><tr><th scope=\"row\">Date</th><td>\n<a href=\"/index.php/299_AC\" title=\"299 AC\">299&#160;AC</a></td></tr><tr><th scope=\"row\">Place</th><td>\nThe <a href=\"/index.php/Crag\" title=\"Crag\">Crag</a>, <a href=\"/index.php/Westerlands\" title=\"Westerlands\">westerlands</a></td></tr><tr><th scope=\"row\">Result</th><td>\n<a href=\"/index.php/House_Stark\" title=\"House Stark\">Stark</a> victory</td></tr><tr><td colspan=\"2\" style=\"text-align:center\">\n<table style=\"width:100%; text-align:left;\">\n<tbody><tr><td colspan=\"2\" style=\"background-color: #B0C4DE; text-align: center;\"><b>Combatants</b></td></tr><tr><td width=\"50%\" style=\"border-right:1px dotted #aaa;\"><a href=\"/index.php/File:House_Baratheon_of_King%27s_Landing.svg\" class=\"image\"><img alt=\"House Baratheon of King&#39;s Landing.svg\" src=\"/images/thumb/6/6f/House_Baratheon_of_King%27s_Landing.svg/33px-House_Baratheon_of_King%27s_Landing.svg.png\" width=\"33\" height=\"36\" srcset=\"/images/thumb/6/6f/House_Baratheon_of_King%27s_Landing.svg/50px-House_Baratheon_of_King%27s_Landing.svg.png 1.5x, /images/thumb/6/6f/House_Baratheon_of_King%27s_Landing.svg/66px-House_Baratheon_of_King%27s_Landing.svg.png 2x\" /></a> <b><a href=\"/index.php/Iron_Throne\" title=\"Iron Throne\">Iron Throne</a></b>/ <a href=\"/index.php/House_Baratheon_of_King%27s_Landing\" title=\"House Baratheon of King&#39;s Landing\">House Baratheon of King's Landing</a>:<br />\n<p><a href=\"/index.php/File:House_Lannister.svg\" class=\"image\"><img alt=\"House Lannister.svg\" src=\"/images/thumb/d/d5/House_Lannister.svg/30px-House_Lannister.svg.png\" width=\"30\" height=\"33\" srcset=\"/images/thumb/d/d5/House_Lannister.svg/45px-House_Lannister.svg.png 1.5x, /images/thumb/d/d5/House_Lannister.svg/60px-House_Lannister.svg.png 2x\" /></a> <a href=\"/index.php/Westerlands\" title=\"Westerlands\">Westerlands</a>, led by <a href=\"/index.php/House_Lannister\" title=\"House Lannister\">House Lannister</a>\n</p>\n<ul><li><a href=\"/index.php/House_Spicer\" title=\"House Spicer\"><img alt=\"House Spicer.svg\" src=\"/images/thumb/e/ee/House_Spicer.svg/20px-House_Spicer.svg.png\" width=\"20\" height=\"22\" srcset=\"/images/thumb/e/ee/House_Spicer.svg/30px-House_Spicer.svg.png 1.5x, /images/thumb/e/ee/House_Spicer.svg/40px-House_Spicer.svg.png 2x\" /></a> <a href=\"/index.php/House_Spicer\" title=\"House Spicer\">House Spicer</a><sup id=\"cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-0\" class=\"reference\"><a href=\"#cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></li>\n<li><a href=\"/index.php/House_Westerling\" title=\"House Westerling\"><img alt=\"House Westerling.svg\" src=\"/images/thumb/f/f3/House_Westerling.svg/20px-House_Westerling.svg.png\" width=\"20\" height=\"22\" srcset=\"/images/thumb/f/f3/House_Westerling.svg/30px-House_Westerling.svg.png 1.5x, /images/thumb/f/f3/House_Westerling.svg/40px-House_Westerling.svg.png 2x\" /></a> <a href=\"/index.php/House_Westerling\" title=\"House Westerling\">House Westerling</a><sup id=\"cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-1\" class=\"reference\"><a href=\"#cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></li></ul></td>\n    <td width=\"50%\"><a href=\"/index.php/File:House_Stark.svg\" class=\"image\"><img alt=\"House Stark.svg\" src=\"/images/thumb/7/7e/House_Stark.svg/30px-House_Stark.svg.png\" width=\"30\" height=\"33\" srcset=\"/images/thumb/7/7e/House_Stark.svg/45px-House_Stark.svg.png 1.5x, /images/thumb/7/7e/House_Stark.svg/60px-House_Stark.svg.png 2x\" /></a> <b><a href=\"/index.php/King_in_the_North\" title=\"King in the North\">Kingdom of the North</a> and <a href=\"/index.php/King_of_the_Trident\" title=\"King of the Trident\">the Trident</a></b>/ <a href=\"/index.php/House_Stark\" title=\"House Stark\">House Stark</a>:<br />\n<p><a href=\"/index.php/North\" title=\"North\">North</a><sup id=\"cite_ref-Robb_3-0\" class=\"reference\"><a href=\"#cite_note-Robb-3\">&#91;N 1&#93;</a></sup>\n</p>\n<ul><li><a href=\"/index.php/House_Umber\" title=\"House Umber\"><img alt=\"House Umber.svg\" src=\"/images/thumb/0/0f/House_Umber.svg/20px-House_Umber.svg.png\" width=\"20\" height=\"22\" srcset=\"/images/thumb/0/0f/House_Umber.svg/30px-House_Umber.svg.png 1.5x, /images/thumb/0/0f/House_Umber.svg/40px-House_Umber.svg.png 2x\" /></a> <a href=\"/index.php/House_Umber\" title=\"House Umber\">House Umber</a><sup id=\"cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-2\" class=\"reference\"><a href=\"#cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></li></ul>\n<p><a href=\"/index.php/File:House_Tully.svg\" class=\"image\"><img alt=\"House Tully.svg\" src=\"/images/thumb/6/61/House_Tully.svg/30px-House_Tully.svg.png\" width=\"30\" height=\"33\" srcset=\"/images/thumb/6/61/House_Tully.svg/45px-House_Tully.svg.png 1.5x, /images/thumb/6/61/House_Tully.svg/60px-House_Tully.svg.png 2x\" /></a> <a href=\"/index.php/Riverlands\" title=\"Riverlands\">Riverlands</a>, led by <a href=\"/index.php/House_Tully\" title=\"House Tully\">House Tully</a>\n</p>\n<ul><li><a href=\"/index.php/House_Frey\" title=\"House Frey\"><img alt=\"House Frey.svg\" src=\"/images/thumb/d/da/House_Frey.svg/20px-House_Frey.svg.png\" width=\"20\" height=\"22\" srcset=\"/images/thumb/d/da/House_Frey.svg/30px-House_Frey.svg.png 1.5x, /images/thumb/d/da/House_Frey.svg/40px-House_Frey.svg.png 2x\" /></a> <a href=\"/index.php/House_Frey\" title=\"House Frey\">House Frey</a><sup id=\"cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-3\" class=\"reference\"><a href=\"#cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></li></ul></td></tr><tr><td colspan=\"2\" style=\"background-color: #B0C4DE; text-align: center;\"><b>Commanders</b></td></tr><tr><td width=\"50%\" style=\"border-right:1px dotted #aaa;\"><a href=\"/index.php/File:House_Spicer.svg\" class=\"image\"><img alt=\"House Spicer.svg\" src=\"/images/thumb/e/ee/House_Spicer.svg/20px-House_Spicer.svg.png\" width=\"20\" height=\"22\" srcset=\"/images/thumb/e/ee/House_Spicer.svg/30px-House_Spicer.svg.png 1.5x, /images/thumb/e/ee/House_Spicer.svg/40px-House_Spicer.svg.png 2x\" /></a> Ser <a href=\"/index.php/Rolph_Spicer\" title=\"Rolph Spicer\">Rolph Spicer</a></td>\n    <td width=\"50%\">                                      <a href=\"/index.php/File:Robb_Stark.svg\" class=\"image\"><img alt=\"Robb Stark.svg\" src=\"/images/thumb/5/5c/Robb_Stark.svg/20px-Robb_Stark.svg.png\" width=\"20\" height=\"22\" srcset=\"/images/thumb/5/5c/Robb_Stark.svg/30px-Robb_Stark.svg.png 1.5x, /images/thumb/5/5c/Robb_Stark.svg/40px-Robb_Stark.svg.png 2x\" /></a> King <a href=\"/index.php/Robb_Stark\" title=\"Robb Stark\">Robb Stark</a><br /><a href=\"/index.php/File:House_Umber.svg\" class=\"image\"><img alt=\"House Umber.svg\" src=\"/images/thumb/0/0f/House_Umber.svg/20px-House_Umber.svg.png\" width=\"20\" height=\"22\" srcset=\"/images/thumb/0/0f/House_Umber.svg/30px-House_Umber.svg.png 1.5x, /images/thumb/0/0f/House_Umber.svg/40px-House_Umber.svg.png 2x\" /></a> <a href=\"/index.php/Jon_Umber_(son_of_Jon)\" title=\"Jon Umber (son of Jon)\">Smalljon Umber</a><br /><a href=\"/index.php/File:House_Frey.svg\" class=\"image\"><img alt=\"House Frey.svg\" src=\"/images/thumb/d/da/House_Frey.svg/20px-House_Frey.svg.png\" width=\"20\" height=\"22\" srcset=\"/images/thumb/d/da/House_Frey.svg/30px-House_Frey.svg.png 1.5x, /images/thumb/d/da/House_Frey.svg/40px-House_Frey.svg.png 2x\" /></a> <a href=\"/index.php/Walder_Frey_(son_of_Ryman)\" title=\"Walder Frey (son of Ryman)\">Black Walder Frey</a></td></tr><tr><td colspan=\"2\" style=\"background-color: #B0C4DE; text-align: center;\"><b>Strength</b></td></tr><tr><td width=\"50%\" style=\"border-right:1px dotted #aaa;\">Garrison of the Crag</td>\n    <td width=\"50%\">                                      Less than 6,000 cavalry</td></tr>\n</tbody></table></td></tr></tbody></table>\n<p>The <b>storming of the Crag</b>,<sup id=\"cite_ref-Rasos2.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-0\" class=\"reference\"><a href=\"#cite_note-Rasos2.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\">&#91;3&#93;</a></sup><sup id=\"cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-4\" class=\"reference\"><a href=\"#cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> <b>conquest of the Crag</b>,<sup id=\"cite_ref-Racok55.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-0\" class=\"reference\"><a href=\"#cite_note-Racok55.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\">&#91;4&#93;</a></sup> or <b>taking of the Crag</b><sup id=\"cite_ref-Racok55.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-1\" class=\"reference\"><a href=\"#cite_note-Racok55.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\">&#91;4&#93;</a></sup> is the final <a href=\"/index.php/House_Stark\" title=\"House Stark\">Stark</a> victory in the <a href=\"/index.php/Westerlands\" title=\"Westerlands\">westerlands</a> during the <a href=\"/index.php/War_of_the_Five_Kings\" title=\"War of the Five Kings\">War of the Five Kings</a>.\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\" lang=\"en\" dir=\"ltr\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Prelude\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Prelude</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#Battle\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Battle</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#Aftermath\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Aftermath</span></a></li>\n<li class=\"toclevel-1 tocsection-4\"><a href=\"#Quotes\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">Quotes</span></a></li>\n<li class=\"toclevel-1 tocsection-5\"><a href=\"#Notes\"><span class=\"tocnumber\">5</span> <span class=\"toctext\">Notes</span></a></li>\n<li class=\"toclevel-1 tocsection-6\"><a href=\"#References\"><span class=\"tocnumber\">6</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h2><span class=\"mw-headline\" id=\"Prelude\">Prelude</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Storming_of_the_Crag&amp;action=edit&amp;section=1\" class=\"tw-editsection-onhover\" title=\"Edit section: Prelude\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>After the <a href=\"/index.php/Battle_of_Oxcross\" title=\"Battle of Oxcross\">Battle of Oxcross</a>, the host of King <a href=\"/index.php/Robb_Stark\" title=\"Robb Stark\">Robb Stark</a> takes castles of the <a href=\"/index.php/Westermen\" title=\"Westermen\">westermen</a>, including <a href=\"/index.php/Taking_of_Ashemark\" title=\"Taking of Ashemark\">Ashemark</a>, and <a href=\"/index.php/Capture_of_Westerland_gold_mines\" class=\"mw-redirect\" title=\"Capture of Westerland gold mines\">three gold mines</a>.<sup id=\"cite_ref-Racok35.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-0\" class=\"reference\"><a href=\"#cite_note-Racok35.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-6\">&#91;5&#93;</a></sup> The <a href=\"/index.php/Northmen\" title=\"Northmen\">northmen</a> move on to the <a href=\"/index.php/Crag\" title=\"Crag\">Crag</a><sup id=\"cite_ref-Racok45.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_7-0\" class=\"reference\"><a href=\"#cite_note-Racok45.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-7\">&#91;6&#93;</a></sup> as part of Robb's plan to draw Lord <a href=\"/index.php/Tywin_Lannister\" title=\"Tywin Lannister\">Tywin Lannister</a> west and out of the <a href=\"/index.php/Riverlands\" title=\"Riverlands\">riverlands</a>.<sup id=\"cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-5\" class=\"reference\"><a href=\"#cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> The <a href=\"/index.php/Castellan\" title=\"Castellan\">castellan</a> of the weakly-garrisoned Crag is Ser <a href=\"/index.php/Rolph_Spicer\" title=\"Rolph Spicer\">Rolph Spicer</a>.<sup id=\"cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-6\" class=\"reference\"><a href=\"#cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p><p>After learning that <a href=\"/index.php/Stannis_Baratheon\" title=\"Stannis Baratheon\">Stannis Baratheon</a> has taken <a href=\"/index.php/Siege_of_Storm%27s_End_(299)\" title=\"Siege of Storm&#39;s End (299)\">Storm's End</a>, <a href=\"/index.php/Catelyn_Stark\" title=\"Catelyn Stark\">Catelyn Stark</a> has Maester <a href=\"/index.php/Vyman\" title=\"Vyman\">Vyman</a> send a <a href=\"/index.php/Raven\" title=\"Raven\">raven</a> from <a href=\"/index.php/Riverrun\" title=\"Riverrun\">Riverrun</a> to Ashemark, hoping that a rider can then catch up to Robb as he advances on the Crag.<sup id=\"cite_ref-Racok45.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_7-1\" class=\"reference\"><a href=\"#cite_note-Racok45.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-7\">&#91;6&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Battle\">Battle</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Storming_of_the_Crag&amp;action=edit&amp;section=2\" class=\"tw-editsection-onhover\" title=\"Edit section: Battle\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>The Crag is stormed at night. <a href=\"/index.php/Jon_Umber_(son_of_Jon)\" title=\"Jon Umber (son of Jon)\">Smalljon Umber</a> and <a href=\"/index.php/Walder_Frey_(son_of_Ryman)\" title=\"Walder Frey (son of Ryman)\">Black Walder Frey</a> lead scaling parties over the walls. Meanwhile, Robb breaks through the main gate with a ram but takes an arrow wound. <a href=\"/index.php/Grey_Wind\" title=\"Grey Wind\">Grey Wind</a>, Robb's <a href=\"/index.php/Direwolf\" title=\"Direwolf\">direwolf</a>, kills a man during the assault.<sup id=\"cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-7\" class=\"reference\"><a href=\"#cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Aftermath\">Aftermath</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Storming_of_the_Crag&amp;action=edit&amp;section=3\" class=\"tw-editsection-onhover\" title=\"Edit section: Aftermath\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>Robb is nursed back to health by Lady <a href=\"/index.php/Jeyne_Westerling\" title=\"Jeyne Westerling\">Jeyne Westerling</a>. After hearing of the supposed deaths at <a href=\"/index.php/Winterfell\" title=\"Winterfell\">Winterfell</a> of his brothers, <a href=\"/index.php/Bran_Stark\" title=\"Bran Stark\">Bran</a> and <a href=\"/index.php/Rickon_Stark\" title=\"Rickon Stark\">Rickon</a>, Robb deflowers Jeyne, and, to spare her dishonor, marries her shortly thereafter. As a consequence of that, the <a href=\"/index.php/House_Westerling\" title=\"House Westerling\">Westerlings</a> join with <a href=\"/index.php/House_Stark\" title=\"House Stark\">House Stark</a>.<sup id=\"cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-8\" class=\"reference\"><a href=\"#cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> However, by marrying Jeyne, Robb breaks his alliance with <a href=\"/index.php/House_Frey\" title=\"House Frey\">House Frey</a>.<sup id=\"cite_ref-Racok64.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_8-0\" class=\"reference\"><a href=\"#cite_note-Racok64.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-8\">&#91;7&#93;</a></sup><sup id=\"cite_ref-Rasos37.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_9-0\" class=\"reference\"><a href=\"#cite_note-Rasos37.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-9\">&#91;8&#93;</a></sup>\n</p><p><a href=\"/index.php/Smallfolk\" title=\"Smallfolk\">Smallfolk</a> at Riverrun celebrate Ser <a href=\"/index.php/Edmure_Tully\" title=\"Edmure Tully\">Edmure Tully</a>'s imminent return after the <a href=\"/index.php/Battle_of_the_Fords\" title=\"Battle of the Fords\">Battle of the Fords</a> and Robb's victory at the Crag with nut-brown <a href=\"/index.php/Ale\" class=\"mw-redirect\" title=\"Ale\">ale</a>.<sup id=\"cite_ref-Racok55.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-2\" class=\"reference\"><a href=\"#cite_note-Racok55.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\">&#91;4&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Quotes\">Quotes</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Storming_of_the_Crag&amp;action=edit&amp;section=4\" class=\"tw-editsection-onhover\" title=\"Edit section: Quotes\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p><b>Robb</b>: I took her castle and she took my heart. The <a href=\"/index.php/Crag\" title=\"Crag\">Crag</a> was weakly garrisoned, so we took it by storm one night. <a href=\"/index.php/Walder_Frey_(son_of_Ryman)\" title=\"Walder Frey (son of Ryman)\">Black Walder</a> and <a href=\"/index.php/Jon_Umber_(son_of_Jon)\" title=\"Jon Umber (son of Jon)\">the Smalljon</a> led scaling parties over the walls, while I broke the main gate with a ram. I took an arrow in the arm just before Ser <a href=\"/index.php/Rolph_Spicer\" title=\"Rolph Spicer\">Rolph</a> yielded us the castle. It seemed nothing at first, but it festered. <a href=\"/index.php/Jeyne_Westerling\" title=\"Jeyne Westerling\">Jeyne</a> had me taken to her own bed, and she nursed me until the fever passed. And she was with me when <a href=\"/index.php/Jon_Umber\" title=\"Jon Umber\">the Greatjon</a> brought me the news of ... of <a href=\"/index.php/Capture_of_Winterfell\" title=\"Capture of Winterfell\">Winterfell</a>. <a href=\"/index.php/Bran_Stark\" title=\"Bran Stark\">Bran</a> and <a href=\"/index.php/Rickon_Stark\" title=\"Rickon Stark\">Rickon</a>. That night, she ... she comforted me, Mother.<br />\n<b>Catelyn</b>: And you wed her the next day.<sup id=\"cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-9\" class=\"reference\"><a href=\"#cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></p></div><div class=\"templatequotecite\"><cite>&#8212;<a href=\"/index.php/Robb_Stark\" title=\"Robb Stark\">Robb Stark</a> and <a href=\"/index.php/Catelyn_Stark\" title=\"Catelyn Stark\">Catelyn Stark</a></cite></div>\n</blockquote>\n<h2><span class=\"mw-headline\" id=\"Notes\">Notes</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Storming_of_the_Crag&amp;action=edit&amp;section=5\" class=\"tw-editsection-onhover\" title=\"Edit section: Notes\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div class=\"references-small\">\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-Robb-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-Robb_3-0\">↑</a></span> <span class=\"reference-text\">Houses <a href=\"/index.php/House_Flint_of_Widow%27s_Watch\" title=\"House Flint of Widow&#39;s Watch\">Flint of Widow's Watch</a>, <a href=\"/index.php/House_Glover\" title=\"House Glover\">Glover</a>, <a href=\"/index.php/House_Hornwood\" title=\"House Hornwood\">Hornwood</a>, <a href=\"/index.php/House_Karstark\" title=\"House Karstark\">Karstark</a>, <a href=\"/index.php/House_Manderly\" title=\"House Manderly\">Manderly</a>, <a href=\"/index.php/House_Mollen\" title=\"House Mollen\">Mollen</a>, and <a href=\"/index.php/House_Mormont\" title=\"House Mormont\">Mormont</a> are part of Robb's host during the <a href=\"/index.php/War_of_the_Five_Kings\" title=\"War of the Five Kings\">War of the Five Kings</a>. They may have accompanied him to the Crag, but their participation in its capture has not been confirmed. <a href=\"/index.php/Barbrey_Dustin\" title=\"Barbrey Dustin\">Barbrey Dustin</a> says that <a href=\"/index.php/Cerwyn\" class=\"mw-redirect\" title=\"Cerwyn\">Cerwyns</a>, <a href=\"/index.php/House_Slate\" title=\"House Slate\">Slates</a>, and <a href=\"/index.php/House_Tallhart\" title=\"House Tallhart\">Tallharts</a> had men with Robb during the war as well.<sup id=\"cite_ref-Radwd46.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\" class=\"reference\"><a href=\"#cite_note-Radwd46.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup></span>\n</li>\n</ol></div></div>\n<h2><span class=\"mw-headline\" id=\"References\">References</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Storming_of_the_Crag&amp;action=edit&amp;section=6\" class=\"tw-editsection-onhover\" title=\"Edit section: References\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div class=\"references-small\">\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-0\">1.0</a></sup> <sup><a href=\"#cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-1\">1.1</a></sup> <sup><a href=\"#cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-2\">1.2</a></sup> <sup><a href=\"#cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-3\">1.3</a></sup> <sup><a href=\"#cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-4\">1.4</a></sup> <sup><a href=\"#cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-5\">1.5</a></sup> <sup><a href=\"#cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-6\">1.6</a></sup> <sup><a href=\"#cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-7\">1.7</a></sup> <sup><a href=\"#cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-8\">1.8</a></sup> <sup><a href=\"#cite_ref-Rasos14.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-9\">1.9</a></sup></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Storm_of_Swords\" title=\"A Storm of Swords\">A Storm of Swords</a></i>, <a href=\"/index.php/A_Storm_of_Swords-Chapter_14\" title=\"A Storm of Swords-Chapter 14\">Chapter 14</a>, Catelyn II.</span>\n</li>\n<li id=\"cite_note-Radwd46.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-Radwd46.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\">↑</a></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Dance_with_Dragons\" title=\"A Dance with Dragons\">A Dance with Dragons</a></i>, <a href=\"/index.php/A_Dance_with_Dragons-Chapter_46\" title=\"A Dance with Dragons-Chapter 46\">Chapter 46</a>, A Ghost in Winterfell.</span>\n</li>\n<li id=\"cite_note-Rasos2.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-Rasos2.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-0\">↑</a></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Storm_of_Swords\" title=\"A Storm of Swords\">A Storm of Swords</a></i>, <a href=\"/index.php/A_Storm_of_Swords-Chapter_2\" title=\"A Storm of Swords-Chapter 2\">Chapter 2</a>, Catelyn I.</span>\n</li>\n<li id=\"cite_note-Racok55.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Racok55.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-0\">4.0</a></sup> <sup><a href=\"#cite_ref-Racok55.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-1\">4.1</a></sup> <sup><a href=\"#cite_ref-Racok55.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-2\">4.2</a></sup></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Clash_of_Kings\" title=\"A Clash of Kings\">A Clash of Kings</a></i>, <a href=\"/index.php/A_Clash_of_Kings-Chapter_55\" title=\"A Clash of Kings-Chapter 55\">Chapter 55</a>, Catelyn VII.</span>\n</li>\n<li id=\"cite_note-Racok35.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-6\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-Racok35.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-0\">↑</a></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Clash_of_Kings\" title=\"A Clash of Kings\">A Clash of Kings</a></i>, <a href=\"/index.php/A_Clash_of_Kings-Chapter_35\" title=\"A Clash of Kings-Chapter 35\">Chapter 35</a>, Bran V.</span>\n</li>\n<li id=\"cite_note-Racok45.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-7\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Racok45.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_7-0\">6.0</a></sup> <sup><a href=\"#cite_ref-Racok45.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_7-1\">6.1</a></sup></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Clash_of_Kings\" title=\"A Clash of Kings\">A Clash of Kings</a></i>, <a href=\"/index.php/A_Clash_of_Kings-Chapter_45\" title=\"A Clash of Kings-Chapter 45\">Chapter 45</a>, Catelyn VI.</span>\n</li>\n<li id=\"cite_note-Racok64.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-8\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-Racok64.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_8-0\">↑</a></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Clash_of_Kings\" title=\"A Clash of Kings\">A Clash of Kings</a></i>, <a href=\"/index.php/A_Clash_of_Kings-Chapter_64\" title=\"A Clash of Kings-Chapter 64\">Chapter 64</a>, Arya X.</span>\n</li>\n<li id=\"cite_note-Rasos37.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-9\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-Rasos37.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_9-0\">↑</a></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Storm_of_Swords\" title=\"A Storm of Swords\">A Storm of Swords</a></i>, <a href=\"/index.php/A_Storm_of_Swords-Chapter_37\" title=\"A Storm of Swords-Chapter 37\">Chapter 37</a>, Jaime V.</span>\n</li>\n</ol></div></div>\n<table cellspacing=\"0\" class=\"navbox\" style=\"border-spacing:0;;\"><tbody><tr><td style=\"padding:2px;\"><table cellspacing=\"0\" class=\"nowraplinks hlist collapsible autocollapse navbox-inner\" style=\"border-spacing:0;background:transparent;width:100%;color:inherit;;;\"><tbody><tr><th scope=\"col\" style=\";\" class=\"navbox-title\" colspan=\"2\"><div class=\"plainlinks hlist\" style=\"display:block;float:left;font-weight:normal;font-size:88%;padding-top:3px;text-align:left;width:6.8em;\"><ul><li class=\"nv-view\"><a href=\"/index.php/Template:War_of_the_Five_Kings\" title=\"Template:War of the Five Kings\"><span title=\"View this template\" style=\";;background:none transparent;border:none;\">v</span></a></li><li class=\"nv-talk\"><a href=\"/index.php/Template_talk:War_of_the_Five_Kings\" title=\"Template talk:War of the Five Kings\"><span title=\"Discuss this template\" style=\";;background:none transparent;border:none;\">d</span></a></li><li class=\"nv-edit\"><a rel=\"nofollow\" class=\"external text\" href=\"https://awoiaf.westeros.org/index.php?title=Template:War_of_the_Five_Kings&amp;action=edit\"><span title=\"Edit this template\" style=\";;background:none transparent;border:none;\">e</span></a></li></ul></div><div class=\"\" style=\"font-size:110%;\">\n<a href=\"/index.php/War_of_the_Five_Kings\" title=\"War of the Five Kings\">Theaters and Campaigns of the War of the Five Kings</a></div></th></tr><tr style=\"height:2px;\"><td></td></tr><tr><td scope=\"row\" class=\"navbox-g