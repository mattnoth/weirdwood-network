  "html": "<div class=\"mw-parser-output\"><table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;font-weight:bold; background: none; line-height: 1.1em;\"><table style=\"width:100%\"><tbody><tr><td style=\"border:none;vertical-align:top;text-align:left;width:50px\"><a href=\"/index.php/House_Mertyns\" title=\"House Mertyns\"><img alt=\"House Mertyns.svg\" src=\"/images/thumb/e/e2/House_Mertyns.svg/50px-House_Mertyns.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/e/e2/House_Mertyns.svg/75px-House_Mertyns.svg.png 1.5x, /images/thumb/e/e2/House_Mertyns.svg/100px-House_Mertyns.svg.png 2x\" /></a></td><td style=\"border:none;vertical-align:middle;text-align:center;padding:0px 7px 5px 7px\"><span style=\"font-size:80%;font-weight:normal\"> Ser</span><br />Michael Mertyns<br /><span style=\"font-size:80%;font-weight:normal\"> the White Owl</span></td><td style=\"border:none;vertical-align:top;text-align:right;width:50px\"><a href=\"/index.php/Kingsguard\" title=\"Kingsguard\"><img alt=\"Kingsguard.svg\" src=\"/images/thumb/6/6d/Kingsguard.svg/50px-Kingsguard.svg.png\" width=\"50\" height=\"55\" srcset=\"/images/thumb/6/6d/Kingsguard.svg/75px-Kingsguard.svg.png 1.5x, /images/thumb/6/6d/Kingsguard.svg/100px-Kingsguard.svg.png 2x\" /></a></td></tr></tbody></table></th></tr><tr><td colspan=\"2\" style=\"text-align:center\"></td></tr><tr><th scope=\"row\">Alias</th><td>\nThe White Owl</td></tr><tr><th scope=\"row\">Title</th><td>\n<a href=\"/index.php/Knight\" title=\"Knight\">Ser</a></td></tr><tr><th scope=\"row\">Allegiances</th><td>\n<div class=\"plainlist\"><ul><li><a href=\"/index.php/House_Mertyns\" title=\"House Mertyns\">House Mertyns</a></li><li><a href=\"/index.php/Kingsguard\" title=\"Kingsguard\">Kingsguard</a></li></ul></div></td></tr><tr><th scope=\"row\">Culture</th><td>\n<a href=\"/index.php/Stormlander\" clas