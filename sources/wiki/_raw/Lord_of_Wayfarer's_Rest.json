>\n<li id=\"cite_note-Radwdappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-Radwdappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_4-0\">↑</a></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Dance_with_Dragons\" title=\"A Dance with Dragons\">A Dance with Dragons</a></i>, <a href=\"/index.php/A_Dance_with_Dragons-Appendix\" title=\"A Dance with Dragons-Appendix\">Appendix</a>.</span>\n</li>\n<li id=\"cite_note-Rfabthe_dying_of_the_dragons_-_the_red_dragon_and_the_gold.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Rfabthe_dying_of_the_dragons_-_the_red_dragon_and_the_gold.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-0\">5.0</a></sup> <sup><a href=\"#cite_ref-Rfabthe_dying_of_the_dragons_-_the_red_dragon_and_the_gold.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-1\">5.1</a></sup> <sup><a href=\"#cite_ref-Rfabthe_dying_of_the_dragons_-_the_red_dragon_and_the_gold.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-2\">5.2</a></sup></span> <span class=\"reference-text\"><i><a href=\"/index.php/Fire_%26_Blood\" title=\"Fire &amp; Blood\">Fire &amp; Blood</a></i>, The Dying of the Dragons - The Red Dragon and the Gold.</span>\n</li>\n<li id=\"cite_note-Rfabthe_dying_of_the_dragons_-_rhaenyra_overthrown.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-6\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Rfabthe_dying_of_the_dragons_-_rhaenyra_overthrown.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-0\">6.0</a></sup> <sup><a href=\"#cite_ref-Rfabthe_dying_of_the_dragons_-_rhaenyra_overthrown.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-1\">6.1</a></sup> <sup><a href=\"#cite_ref-Rfabthe_dying_of_the_dragons_-_rhaenyra_overthrown.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-2\">6.2</a></sup> <sup><a href=\"#cite_ref-Rfabthe_dying_of_the_dragons_-_rhaenyra_overthrown.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-3\">6.3</a></sup></span> <span class=\"reference-text\"><i><a href=\"/index.php/Fire_%26