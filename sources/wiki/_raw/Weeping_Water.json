php/Skane\" title=\"Skane\">Skane</a></li>\n<li><a href=\"/index.php/Stony_Shore\" title=\"Stony Shore\">Stony Shore</a></li>\n<li><a href=\"/index.php/Sunset_Sea\" title=\"Sunset Sea\">Sunset Sea</a></li>\n<li><a class=\"mw-selflink selflink\">Weeping Water</a></li>\n<li><a href=\"/index.php/White_Knife\" title=\"White Knife\">White Knife</a></li>\n<li><a href=\"/index.php/Wolfswood\" title=\"Wolfswood\">Wolfswood</a></li></ul>\n</div></td></tr></tbody></table></td></tr></tbody></table>\n\n<!-- \nNewPP limit report\nCached time: 20260403223116\nCache expiry: 1209600\nDynamic content: false\nCPU time usage: 0.056 seconds\nReal time usage: 0.061 seconds\nPreprocessor visited node count: 1116/1000000\nPreprocessor generated node count: 19664/1000000\nPost‐expand include size: 15501/2097152 bytes\nTemplate argument size: 5292/2097152 bytes\nHighest expansion depth: 17/40\nExpensive parser function count: 1/100\nUnstrip recursion depth: 0/20\nUnstrip post‐expand size: 2469/5000000 bytes\n-->\n<!--\nTransclusion expansion time report (%,ms,calls,template)\n100.00%   38.056      1 -total\n 36.06%   13.722      1 Template:Location_map\n 34.06%   12.960      1 Template:Location_map+\n 26.82%   10.208      4 Template:Ref\n 23.73%    9.029      1 Template:Region_North\n 22.09%    8.408      1 Template:Navbox\n 21.90%    8.336      1 Template:Location_map~\n 17.45%    6.641      4 Template:Ref/core\n 10.62%    4.040      1 Template:Navbar\n  9.29%    3.537     10 Template:Location_map_File:The_North.png\n-->\n</div>\n<!-- Saved in parser cache with key westeros_awoiaftest-mw_:pcache:idhash:5189-0!canonical and timestamp 20260403223116 and revision id 259808\n -->\n",
