{
  "page": "Ten Towers",
  "html": "<div class=\"mw-parser-output\"><table class=\"infobox\" style=\"min-width:22em;max-width:32em;border-collapse:separate;border-spacing:3px\"><tbody><tr><th colspan=\"2\" style=\"text-align:center;font-size:125%;font-weight:bold;background: #DEDEE2;\">Ten Towers</th></tr><tr><td colspan=\"2\" style=\"text-align:center\">\nCastle</td></tr><tr><td colspan=\"2\" class=\"infobox-image\" style=\"text-align:center\">\n<a href=\"/index.php/File:Ten_towers_game_of_thrones_lcg_by_jcbarquet.jpg\" class=\"image\"><img alt=\"Ten towers game of thrones lcg by jcbarquet.jpg\" src=\"/images/thumb/5/57/Ten_towers_game_of_thrones_lcg_by_jcbarquet.jpg/350px-Ten_towers_game_of_thrones_lcg_by_jcbarquet.jpg\" width=\"350\" height=\"257\" srcset=\"/images/thumb/5/57/Ten_towers_game_of_thrones_lcg_by_jcbarquet.jpg/525px-Ten_towers_game_of_thrones_lcg_by_jcbarquet.jpg 1.5x, /images/thumb/5/57/Ten_towers_game_of_thrones_lcg_by_jcbarquet.jpg/700px-Ten_towers_game_of_thrones_lcg_by_jcbarquet.jpg 2x\" /></a><div>Ten Towers, by Juan Carlos Barquet © Fantasy Flight Games</div></td></tr><tr><th scope=\"row\">Location</th><td>\n<a href=\"/index.php/Harlaw\" title=\"Harlaw\">Harlaw</a>, <a href=\"/index.php/Iron_Islands\" title=\"Iron Islands\">Iron Islands</a></td></tr><tr><th scope=\"row\">Government</th><td>\n<a href=\"/index.php/House_Harlaw\" title=\"House Harlaw\">House Harlaw</a></td></tr><tr><th scope=\"row\">Ruler</th><td>\nLord <a href=\"/index.php/Rodrik_Harlaw\" title=\"Rodrik Harlaw\">Rodrik Harlaw</a></td></tr><tr><th scope=\"row\">Founded</th><td>\nby Lord <a href=\"/index.php/Theomore_Harlaw\" title=\"Theomore Harlaw\">Theomore Harlaw</a></td></tr><tr><th scope=\"row\">Named for</th><td>\nthe castle's ten towers</td></tr><tr><th scope=\"row\">Notable places</th><td>\n<a href=\"/index.php/Book_Tower\" title=\"Book Tower\">Book Tower</a>, <a href=\"/index.php/Widow%27s_Tower_(Ten_Towers)\" title=\"Widow&#39;s Tower (Ten Towers)\">Widow's Tower</a>, <a href=\"/index.php/Long_Stone_Quay\" title=\"Long Stone Quay\">Long Stone Quay</a></td></tr></tbody></table>\n<div class=\"thumb tright\">\n<div class=\"thumbinner\" style=\"width:352px;\">\n<div style=\"position: relative; border: 1px solid lightgray\"><a href=\"/index.php/File:Iron_Islands.jpg\" class=\"image\" title=\"The Iron Islands and the location of Ten Towers\"><img alt=\"The Iron Islands and the location of Ten Towers\" src=\"/images/thumb/b/bd/Iron_Islands.jpg/350px-Iron_Islands.jpg\" width=\"350\" height=\"240\" srcset=\"/images/thumb/b/bd/Iron_Islands.jpg/525px-Iron_Islands.jpg 1.5x, /images/thumb/b/bd/Iron_Islands.jpg/700px-Iron_Islands.jpg 2x\" /></a><div style=\"position: absolute; z-index: 2; top: 67.2%; left: 49.2%; height: 0; width: 0; margin: 0; padding: 0;\"><div style=\"position: relative; text-align: center; left: -4px; top: -4px; width: 7px; font-size: 7px;\"><img alt=\"The Iron Islands and the location of Ten Towers\" src=\"/images/thumb/b/b4/Red_pog.png/7px-Red_pog.png\" title=\"Ten Towers\" width=\"7\" height=\"7\" srcset=\"/images/thumb/b/b4/Red_pog.png/11px-Red_pog.png 1.5x, /images/thumb/b/b4/Red_pog.png/14px-Red_pog.png 2x\" /></div><div style=\"font-size:&#160;%; line-height: 110%; z-index:90; position: relative; top: -1.5em; width: 6em; left: -6.5em; text-align: right;\"><span style=\"padding: 1px;\">Ten Towers</span></div></div></div>\n<div class=\"thumbcaption\">The <a href=\"/index.php/Iron_Islands\" title=\"Iron Islands\">Iron Islands</a> and the location of Ten Towers\n</div>\n</div>\n</div>\n<p><b>Ten Towers</b><sup id=\"cite_ref-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-0\" class=\"reference\"><a href=\"#cite_note-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup><sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup><sup id=\"cite_ref-Radwd26.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-0\" class=\"reference\"><a href=\"#cite_note-Radwd26.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup> or <b>the Ten Towers</b><sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-1\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup> is the seat of <a href=\"/index.php/House_Harlaw\" title=\"House Harlaw\">House Harlaw</a> on the eastern coast of the isle of <a href=\"/index.php/Harlaw\" title=\"Harlaw\">Harlaw</a> in the <a href=\"/index.php/Iron_Islands\" title=\"Iron Islands\">Iron Islands</a>.<sup id=\"cite_ref-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-1\" class=\"reference\"><a href=\"#cite_note-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup><sup id=\"cite_ref-4\" class=\"reference\"><a href=\"#cite_note-4\">&#91;4&#93;</a></sup>\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\" lang=\"en\" dir=\"ltr\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Layout\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Layout</span></a></li>\n<li class=\"toclevel-1 tocsection-2\"><a href=\"#History\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">History</span></a></li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#Recent_Events\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">Recent Events</span></a>\n<ul>\n<li class=\"toclevel-2 tocsection-4\"><a href=\"#A_Feast_for_Crows\"><span class=\"tocnumber\">3.1</span> <span class=\"toctext\"><i>A Feast for Crows</i></span></a></li>\n<li class=\"toclevel-2 tocsection-5\"><a href=\"#A_Dance_with_Dragons\"><span class=\"tocnumber\">3.2</span> <span class=\"toctext\"><i>A Dance with Dragons</i></span></a></li>\n</ul>\n</li>\n<li class=\"toclevel-1 tocsection-6\"><a href=\"#Quotes\"><span class=\"tocnumber\">4</span> <span class=\"toctext\">Quotes</span></a></li>\n<li class=\"toclevel-1 tocsection-7\"><a href=\"#Chapters_that_take_place_at_Ten_Towers\"><span class=\"tocnumber\">5</span> <span class=\"toctext\">Chapters that take place at Ten Towers</span></a></li>\n<li class=\"toclevel-1 tocsection-8\"><a href=\"#References\"><span class=\"tocnumber\">6</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h2><span class=\"mw-headline\" id=\"Layout\">Layout</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ten_Towers&amp;action=edit&amp;section=1\" class=\"tw-editsection-onhover\" title=\"Edit section: Layout\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>The castle consists of ten towers all shaped differently, with wallwalks, covered bridges, kitchens, and dungeons.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-2\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>The hall of Ten Towers contains the high seat of <a href=\"/index.php/House_Harlaw\" title=\"House Harlaw\">House Harlaw</a>, with two giant scythes of beaten <a href=\"/index.php/Silver\" title=\"Silver\">silver</a> hanging crossed above the seat.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-3\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>The <a href=\"/index.php/Book_Tower\" title=\"Book Tower\">Book Tower</a>, the fattest of the castle's towers, is octagonal and made of large block stones.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-4\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup> Lord <a href=\"/index.php/Rodrik_Harlaw\" title=\"Rodrik Harlaw\">Rodrik Harlaw</a> does not allow food or drink in his library.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-5\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup> The yard below contains a well.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-6\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>The <a href=\"/index.php/Widow%27s_Tower_(Ten_Towers)\" title=\"Widow&#39;s Tower (Ten Towers)\">Widow's Tower</a> is so called due to the presence of Rodrik's sister, Lady <a href=\"/index.php/Gwynesse_Harlaw\" title=\"Gwynesse Harlaw\">Gwynesse Harlaw</a>.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-7\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>A village lies near Ten Towers.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-8\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup> There is good fishing off the <a href=\"/index.php/Long_Stone_Quay\" title=\"Long Stone Quay\">Long Stone Quay</a>.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-9\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"History\">History</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ten_Towers&amp;action=edit&amp;section=2\" class=\"tw-editsection-onhover\" title=\"Edit section: History\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<p>The newest castle in the <a href=\"/index.php/Iron_Islands\" title=\"Iron Islands\">Iron Islands</a>, Ten Towers was built by Lord <a href=\"/index.php/Theomore_Harlaw\" title=\"Theomore Harlaw\">Theomore Harlaw</a>, who blamed the deaths of three infant sons on the dampness of ancient <a href=\"/index.php/Harlaw_Hall\" title=\"Harlaw Hall\">Harlaw Hall</a>, which often flooded. The new castle was built at a better site, but the mercurial Theomore constructed ten towers different in appearance.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-10\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>While growing up <a href=\"/index.php/Asha_Greyjoy\" title=\"Asha Greyjoy\">Asha Greyjoy</a> felt more at home at Ten Towers than at the <a href=\"/index.php/House_Greyjoy\" title=\"House Greyjoy\">Greyjoy</a> seat of <a href=\"/index.php/Pyke\" title=\"Pyke\">Pyke</a>. She enjoyed racing amongst Ten Towers' walks and bridges and reading in Lord <a href=\"/index.php/Rodrik_Harlaw\" title=\"Rodrik Harlaw\">Rodrik Harlaw</a>'s library.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-11\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup> When the <a href=\"/index.php/Faith_of_the_Seven\" title=\"Faith of the Seven\">Faith of the Seven</a> was tolerated in the <a href=\"/index.php/Iron_Islands\" title=\"Iron Islands\">Iron Islands</a>, Rodrik kept <a href=\"/index.php/Septon\" title=\"Septon\">septons</a> at the castle to maintain his library.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-12\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>Rodrik's older sister, Lady <a href=\"/index.php/Gwynesse_Harlaw\" title=\"Gwynesse Harlaw\">Gwynesse Harlaw</a>, came back to Ten Towers after the death of her husband in the <a href=\"/index.php/Sea_battle_off_Fair_Isle\" title=\"Sea battle off Fair Isle\">sea battle off Fair Isle</a> during <a href=\"/index.php/Greyjoy%27s_Rebellion\" title=\"Greyjoy&#39;s Rebellion\">Greyjoy's Rebellion</a> in <a href=\"/index.php/289_AC\" title=\"289 AC\">289&#160;AC</a>, saying she would remain until her grief had passed. Her residence is now known as the Widow's Tower, and the still-grieving Gwynesse believes that the castle should belong to her instead of the younger Rodrik.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-13\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p><a href=\"/index.php/Alannys_Harlaw\" title=\"Alannys Harlaw\">Alannys Harlaw</a>, the wife of <a href=\"/index.php/Balon_Greyjoy\" title=\"Balon Greyjoy\">Balon Greyjoy</a>, <a href=\"/index.php/Lord_of_the_Iron_Islands\" title=\"Lord of the Iron Islands\">Lord of the Iron Islands</a>, moved to Ten Towers to live with her sister Gwynesse,<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-14\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup> as it is less raw on <a href=\"/index.php/Harlaw\" title=\"Harlaw\">Harlaw</a> than on the <a href=\"/index.php/Pyke_(island)\" title=\"Pyke (island)\">isle of Pyke</a>.<sup id=\"cite_ref-Racok11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_5-0\" class=\"reference\"><a href=\"#cite_note-Racok11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-5\">&#91;5&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Recent_Events\">Recent Events</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ten_Towers&amp;action=edit&amp;section=3\" class=\"tw-editsection-onhover\" title=\"Edit section: Recent Events\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span class=\"mw-headline\" id=\"A_Feast_for_Crows\"><i>A Feast for Crows</i></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ten_Towers&amp;action=edit&amp;section=4\" class=\"tw-editsection-onhover\" title=\"Edit section: A Feast for Crows\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:352px;\"><a href=\"/index.php/File:Nacho_Molia_the_Reader.jpg\" class=\"image\"><img alt=\"\" src=\"/images/thumb/8/81/Nacho_Molia_the_Reader.jpg/350px-Nacho_Molia_the_Reader.jpg\" width=\"350\" height=\"219\" class=\"thumbimage\" srcset=\"/images/thumb/8/81/Nacho_Molia_the_Reader.jpg/525px-Nacho_Molia_the_Reader.jpg 1.5x, /images/8/81/Nacho_Molia_the_Reader.jpg 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/index.php/File:Nacho_Molia_the_Reader.jpg\" class=\"internal\" title=\"Enlarge\"></a></div>Lord <a href=\"/index.php/Rodrik_Harlaw\" title=\"Rodrik Harlaw\">Rodrik Harlaw</a> and his library, by Nacho Molina © Fantasy Flight Games</div></div></div>\n<p>Rival claimants arise in the <a href=\"/index.php/Iron_Islands\" title=\"Iron Islands\">Iron Islands</a> after the death of <a href=\"/index.php/Balon_Greyjoy\" title=\"Balon Greyjoy\">Balon Greyjoy</a>, <a href=\"/index.php/King_of_the_Isles_and_the_North\" title=\"King of the Isles and the North\">King of the Isles and the North</a>. Lord <a href=\"/index.php/Rodrik_Harlaw\" title=\"Rodrik Harlaw\">Rodrik Harlaw</a> announces that Balon intended to be succeeded by <a href=\"/index.php/Asha_Greyjoy\" title=\"Asha Greyjoy\">Asha Greyjoy</a>, Balon's daughter and Rodrik's niece, and Lord Harlaw calls her supporters to Ten Towers.<sup id=\"cite_ref-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-2\" class=\"reference\"><a href=\"#cite_note-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup> <a href=\"/index.php/Aeron_Greyjoy\" title=\"Aeron Greyjoy\">Aeron Greyjoy</a> calls for a <a href=\"/index.php/Kingsmoot\" title=\"Kingsmoot\">kingsmoot</a> to be held to choose Balon's successor.<sup id=\"cite_ref-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-3\" class=\"reference\"><a href=\"#cite_note-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p><p>Lord <a href=\"/index.php/Baelor_Blacktyde\" title=\"Baelor Blacktyde\">Baelor Blacktyde</a> briefly visits Rodrik at Ten Towers before continuing on to <a href=\"/index.php/Old_Wyk\" title=\"Old Wyk\">Old Wyk</a>.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-15\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup> Potential supporters of <a href=\"/index.php/Asha_Greyjoy\" title=\"Asha Greyjoy\">Asha Greyjoy</a> who assemble at Ten Towers include <a href=\"/index.php/House_Botley\" title=\"House Botley\">Botleys</a>, <a href=\"/index.php/House_Myre\" title=\"House Myre\">Myres</a>, <a href=\"/index.php/House_Stonetree\" title=\"House Stonetree\">Stonetrees</a>, and <a href=\"/index.php/House_Volmark\" title=\"House Volmark\">Volmarks</a>. Harlaw cousins include <a href=\"/index.php/Boremund_Harlaw\" title=\"Boremund Harlaw\">Boremund</a>, <a href=\"/index.php/Hotho_Harlaw\" title=\"Hotho Harlaw\">Hotho Humpback</a>, Ser <a href=\"/index.php/Harras_Harlaw\" title=\"Harras Harlaw\">Harras</a>, and <a href=\"/index.php/Sigfryd_Harlaw\" title=\"Sigfryd Harlaw\">Sigfryd Silverhair</a>.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-16\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>Upon arriving at Ten Towers, Asha orders the steward <a href=\"/index.php/Three-Tooth\" title=\"Three-Tooth\">Three-Tooth</a> to have the captive Lady <a href=\"/index.php/Sybelle_Glover\" title=\"Sybelle Glover\">Sybelle Glover</a> and her children, <a href=\"/index.php/Gawen_Glover\" title=\"Gawen Glover\">Gawen</a> and <a href=\"/index.php/Erena_Glover\" title=\"Erena Glover\">Erena</a>, comfortably quartered in one of the towers instead of the dungeons, and to have warm food served to the crew of <i><a href=\"/index.php/Black_Wind\" title=\"Black Wind\">Black Wind</a></i>. Asha delays seeing her mother Alannys in the <a href=\"/index.php/Widow%27s_Tower_(Ten_Towers)\" title=\"Widow&#39;s Tower (Ten Towers)\">Widow's Tower</a> until the next morning, and instead meets her uncle, Lord Rodrik, within the <a href=\"/index.php/Book_Tower\" title=\"Book Tower\">Book Tower</a>. Worried that Asha will lose to her uncles <a href=\"/index.php/Euron_Greyjoy\" title=\"Euron Greyjoy\">Euron</a> or <a href=\"/index.php/Victarion_Greyjoy\" title=\"Victarion Greyjoy\">Victarion</a> at the kingsmoot, Rodrik offers to name her heir to Ten Towers if she remains on <a href=\"/index.php/Harlaw\" title=\"Harlaw\">Harlaw</a>, though Harras would remain heir to <a href=\"/index.php/House_Harlaw\" title=\"House Harlaw\">House Harlaw</a> itself. Asha refuses and wants the <a href=\"/index.php/Seastone_Chair\" title=\"Seastone Chair\">Seastone Chair</a> instead.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-17\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p><p>Euron ends up chosen by the <a href=\"/index.php/Ironborn\" title=\"Ironborn\">ironborn</a> who assemble at <a href=\"/index.php/Nagga%27s_hill\" title=\"Nagga&#39;s hill\">Nagga's hill</a> for the <a href=\"/index.php/Kingsmoot_on_Old_Wyk\" title=\"Kingsmoot on Old Wyk\">kingsmoot on Old Wyk</a>.<sup id=\"cite_ref-Raffc19.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-0\" class=\"reference\"><a href=\"#cite_note-Raffc19.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-6\">&#91;6&#93;</a></sup>\n</p>\n<h3><span class=\"mw-headline\" id=\"A_Dance_with_Dragons\"><i>A Dance with Dragons</i></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ten_Towers&amp;action=edit&amp;section=5\" class=\"tw-editsection-onhover\" title=\"Edit section: A Dance with Dragons\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>When Euron Crow's Eye is chosen, Asha flees from Old Wyk back to Ten Towers on Harlaw to bid farewell to her mother. While taking on provisions, she learns that Euron has had her wed to <a href=\"/index.php/Erik_Ironmaker\" title=\"Erik Ironmaker\">Erik Ironmaker</a> using a <a href=\"/index.php/Seal\" title=\"Seal\">seal</a> as her proxy.<sup id=\"cite_ref-Radwd26.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-1\" class=\"reference\"><a href=\"#cite_note-Radwd26.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup> Asha leaves Gawen and Erena Glover at Ten Towers in the care of Alannys and her aunt, <a href=\"/index.php/Gwynesse_Harlaw\" title=\"Gwynesse Harlaw\">Gwynesse Harlaw</a>, but continues on to <a href=\"/index.php/Deepwood_Motte\" title=\"Deepwood Motte\">Deepwood Motte</a> in the <a href=\"/index.php/Wolfswood\" title=\"Wolfswood\">wolfswood</a> with the captive Lady Glover.<sup id=\"cite_ref-Radwd26.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-2\" class=\"reference\"><a href=\"#cite_note-Radwd26.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\">&#91;3&#93;</a></sup>\n</p>\n<h2><span class=\"mw-headline\" id=\"Quotes\">Quotes</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ten_Towers&amp;action=edit&amp;section=6\" class=\"tw-editsection-onhover\" title=\"Edit section: Quotes\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div class=\"thumb tright\"><div class=\"thumbinner\" style=\"width:352px;\"><a href=\"/index.php/File:Trevor_Cook_Ten_Towers.JPG\" class=\"image\"><img alt=\"\" src=\"/images/thumb/f/f3/Trevor_Cook_Ten_Towers.JPG/350px-Trevor_Cook_Ten_Towers.JPG\" width=\"350\" height=\"227\" class=\"thumbimage\" srcset=\"/images/thumb/f/f3/Trevor_Cook_Ten_Towers.JPG/525px-Trevor_Cook_Ten_Towers.JPG 1.5x, /images/f/f3/Trevor_Cook_Ten_Towers.JPG 2x\" /></a>  <div class=\"thumbcaption\"><div class=\"magnify\"><a href=\"/index.php/File:Trevor_Cook_Ten_Towers.JPG\" class=\"internal\" title=\"Enlarge\"></a></div>Ten Towers by Trevor Cook © Fantasy Flight Games</div></div></div>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p>Lady <a href=\"/index.php/Gwynesse_Harlaw\" title=\"Gwynesse Harlaw\">Gwynesse</a> had come home to mourn after her husband had died off <a href=\"/index.php/Sea_battle_off_Fair_Isle\" title=\"Sea battle off Fair Isle\">Fair Isle</a> during <a href=\"/index.php/Balon_Greyjoy\" title=\"Balon Greyjoy\">Balon Greyjoy</a>'s <a href=\"/index.php/Greyjoy%27s_Rebellion\" title=\"Greyjoy&#39;s Rebellion\">first rebellion</a>. \"I will only stay until my grief has passed,\" she had told her brother, famously, \"though by rights Ten Towers should be mine, for I am seven years your elder.\" Long years had passed since then, but still the widow lingered, grieving, and muttering from time to time that the castle should be hers. And now Lord <a href=\"/index.php/Rodrik_Harlaw\" title=\"Rodrik Harlaw\">Rodrik</a> has a <a href=\"/index.php/Alannys_Harlaw\" title=\"Alannys Harlaw\">second half-mad widowed sister</a> beneath his roof, Asha reflected. Small wonder if he seeks solace in his books.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-18\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup></p></div><div class=\"templatequotecite\"><cite>&#8212;thoughts of <a href=\"/index.php/Asha_Greyjoy\" title=\"Asha Greyjoy\">Asha Greyjoy</a></cite></div>\n</blockquote>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p>It was good to walk these halls again. Ten Towers had always felt like home to Asha, more so than <a href=\"/index.php/Pyke\" title=\"Pyke\">Pyke</a>. Not one castle, ten castles squashed together, she had thought, the first time she had seen it.<sup id=\"cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-19\" class=\"reference\"><a href=\"#cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup></p></div><div class=\"templatequotecite\"><cite>&#8212;thoughts of <a href=\"/index.php/Asha_Greyjoy\" title=\"Asha Greyjoy\">Asha Greyjoy</a></cite></div>\n</blockquote>\n<h2><span class=\"mw-headline\" id=\"Chapters_that_take_place_at_Ten_Towers\">Chapters that take place at Ten Towers</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ten_Towers&amp;action=edit&amp;section=7\" class=\"tw-editsection-onhover\" title=\"Edit section: Chapters that take place at Ten Towers\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<ul><li><a href=\"/index.php/A_Feast_for_Crows-Chapter_11\" title=\"A Feast for Crows-Chapter 11\"><i>A Feast for Crows</i>: 11. The Kraken's Daughter</a></li></ul>\n<h2><span class=\"mw-headline\" id=\"References\">References</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Ten_Towers&amp;action=edit&amp;section=8\" class=\"tw-editsection-onhover\" title=\"Edit section: References\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div class=\"references-small\">\n<div class=\"mw-references-wrap\"><ol class=\"references\">\n<li id=\"cite_note-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-0\">1.0</a></sup> <sup><a href=\"#cite_ref-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-1\">1.1</a></sup> <sup><a href=\"#cite_ref-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-2\">1.2</a></sup> <sup><a href=\"#cite_ref-Raffc1.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-3\">1.3</a></sup></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Feast_for_Crows\" title=\"A Feast for Crows\">A Feast for Crows</a></i>, <a href=\"/index.php/A_Feast_for_Crows-Chapter_1\" title=\"A Feast for Crows-Chapter 1\">Chapter 1</a>, The Prophet.</span>\n</li>\n<li id=\"cite_note-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\">2.00</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-1\">2.01</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-2\">2.02</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-3\">2.03</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-4\">2.04</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-5\">2.05</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-6\">2.06</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-7\">2.07</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-8\">2.08</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-9\">2.09</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-10\">2.10</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-11\">2.11</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-12\">2.12</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-13\">2.13</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-14\">2.14</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-15\">2.15</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-16\">2.16</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-17\">2.17</a></sup> <sup><a href=\"#cite_ref-Raffc11.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-18\