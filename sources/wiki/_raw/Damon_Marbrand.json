B4.7D.7D.7D_1-0\" class=\"reference\"><a href=\"#cite_note-Rasosappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></td></tr><tr><th scope=\"row\">Allegiance</th><td>\n<a href=\"/index.php/House_Marbrand\" title=\"House Marbrand\">House Marbrand</a></td></tr><tr><th scope=\"row\">Culture</th><td>\n<a href=\"/index.php/Westermen\" title=\"Westermen\">Westermen</a></td></tr><tr><th scope=\"row\">Issue</th><td>\n<a href=\"/index.php/Addam_Marbrand\" title=\"Addam Marbrand\">Addam Marbrand</a><sup id=\"cite_ref-Rasosappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-1\" class=\"reference\"><a href=\"#cite_note-Rasosappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup></td></tr><tr><th scope=\"row\">Books</th><td>\n<div class=\"plainlist\"><ul><li><i><a href=\"/index.php/A_Storm_of_Swords\" title=\"A Storm of Swords\">A Storm of Swords</a></i> (appendix)</li><li><i><a href=\"/index.php/A_Feast_for_Crows\" title=\"A Feast for Crows\">A Feast for Crows</a></i> (appendix)</li><li><i><a href=\"/index.php/A_Dance_with_Dragons\" title=\"A Dance with Dragons\">A Dance with Dragons</a></i> (appendix)</li></ul></div></td></tr></tbody></table>\n<p><b>Damon Marbrand</b> is the Lord of <a href=\"/index.php/Ashemark\" title=\"Ashemark\">Ashemark</a> and the head of <a href=\"/index.php/House_Marbrand\" title=\"House Marbrand\">House Marbrand</a> in the <a href=\"/index.php/Westerlands\" title=\"Westerlands\">westerlands</a>. He is the father of Ser <a href=\"/index.php/Addam_Marbrand\" title=\"Addam Marbrand\">Addam Marbrand</a>.<sup id=\"cite_ref-Rasosappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_1-2\" class=\"reference\"><a href=\"#cite_note-Rasosappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-1\">&#91;1&#93;</a></sup>\n</p>\n<div id=\"toc\" class=\"toc\"><div class=\"toctitle\" lang=\"en\" dir=\"ltr\"><h2>Contents</h2></div>\n<ul>\n<li class=\"toclevel-1 tocsection-1\"><a href=\"#Recent_Events\"><span class=\"tocnumber\">1</span> <span class=\"toctext\">Recent Events</span></a>\n<ul>\n<li class=\"toclevel-2 tocsection-2\"><a href=\"#A_Clash_of_Kings\"><span class=\"tocnumber\">1.1</span> <span class=\"toctext\"><i>A Clash of Kings</i></span></a></li>\n</ul>\n</li>\n<li class=\"toclevel-1 tocsection-3\"><a href=\"#Family\"><span class=\"tocnumber\">2</span> <span class=\"toctext\">Family</span></a></li>\n<li class=\"toclevel-1 tocsection-4\"><a href=\"#References\"><span class=\"tocnumber\">3</span> <span class=\"toctext\">References</span></a></li>\n</ul>\n</div>\n\n<h2><span class=\"mw-headline\" id=\"Recent_Events\">Recent Events</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Damon_Marbrand&amp;action=edit&amp;section=1\" class=\"tw-editsection-onhover\" title=\"Edit section: Recent Events\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<h3><span class=\"mw-headline\" id=\"A_Clash_of_Kings\"><i>A Clash of Kings</i></span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Damon_Marbrand&amp;action=edit&amp;section=2\" class=\"tw-editsection-onhover\" title=\"Edit section: A Clash of Kings\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h3>\n<p>Damon's seat, <a href=\"/index.php/Ashemark\" title=\"Ashemark\">Ashemark</a>, is <a href=\"/index.php/Taking_of_Ashemark\" title=\"Taking of Ashemark\">taken</a> by <a href=\"/index.php/Robb_Stark\" title=\"Robb Stark\">Robb Stark</a> during the <a href=\"/index.php/King_in_the_North\" title=\"King in the North\">King in the North</a>'s campaign in the <a href=\"/index.php/Westerlands\" title=\"Westerlands\">westerlands</a>.<sup id=\"cite_ref-Racok35.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\" class=\"reference\"><a href=\"#cite_note-Racok35.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\">&#91;2&#93;</a></sup>\n</p>\n<h2