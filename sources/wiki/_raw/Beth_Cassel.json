le=\"border-bottom:1px solid black;\"><div style=\"width:2em;height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td style=\"border-right:1px solid black;border-bottom:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td style=\"border-bottom:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"2\" style=\"border-bottom:1px solid black;\"><div style=\"width:2em;height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td style=\"border-bottom:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td rowspan=\"2\"><div style=\"width:1em;height:2em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td><div style=\"width:1em; height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td style=\"border-bottom:1px solid black\"><div style=\"width:1em; height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"2\" style=\"border-bottom:1px solid black;\"><div style=\"width:2em;height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td style=\"border-right:1px solid black;border-bottom:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td style=\"border-bottom:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"2\" style=\"border-bottom:1px solid black;\"><div style=\"width:2em;height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td style=\"border-bottom:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td rowspan=\"2\"><div style=\"width:1em;height:2em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td></tr><tr align=\"center\"><td style=\"border-right:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"2\"><div style=\"width:2em; height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"2\"><div style=\"width:2em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"2\"><div style=\"width:2em; height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td style=\"border-right:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td style=\"border-right:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"2\"><div style=\"width:2em; height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"2\"><div style=\"width:2em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td><td colspan=\"2\"><div style=\"width:2em; height:1em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td style=\"border-right:1px solid black\"><div style=\"width:1em;height:1em\"><span style=\"font:1px/1px serif\">&#160;</span></div></td></tr>\n<tr align=\"center\"><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\">Daughters</td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\"><a class=\"mw-selflink selflink\">Beth</a></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\">Three sons</td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td><td colspan=\"6\" rowspan=\"2\" style=\"border: 2px solid black; padding: 0.2em;&#160;;\"><a href=\"/index.php/Jory_Cassel\" title=\"Jory Cassel\">Jory</a></td><td rowspan=\"2\" colspan=\"2\"><div style=\"width:2em; height:2em;\"><span style=\"font:1px/1px serif;\">&#160;</span></div></td></tr><tr align=\"center\"></tr>\n</tbody></table></div>\n<p><br />\n</p>\n<h2><span class=\"mw-headline\" id=\"Quotes\">Quotes</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Beth_Cassel&amp;action=edit&amp;section=10\" class=\"tw-editsection-onhover\" title=\"Edit section: Quotes\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p><b>Jeyne</b>: <a href=\"/index.php/Joffrey_Baratheon\" title=\"Joffrey Baratheon\">Joffrey</a> likes your sister. He told her she was very beautiful.<br />\n</p><p><b>Beth</b>: He's going to marry her. Then <a href=\"/index.php/Sansa_Stark\" title=\"Sansa Stark\">Sansa</a> will be queen of all the realm.<br />\n</p>\n<b>Sansa</b>: Beth, you shouldn't make up stories.<sup id=\"cite_ref-Ragot7.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_6-1\" class=\"reference\"><a href=\"#cite_note-Ragot7.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-6\">&#91;6&#93;</a></sup><p class=\"mw-empty-elt\"></p></div><div class=\"templatequotecite\"><cite>&#8212;<a href=\"/index.php/Jeyne_Poole\" title=\"Jeyne Poole\">Jeyne Poole</a>, Beth, and <a href=\"/index.php/Sansa_Stark\" title=\"Sansa Stark\">Sansa Stark</a></cite></div>\n</blockquote>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p><b>Rodrik</b>: This is craven. To use a child so... this is despicable.<br />\n<b>Theon</b>: Oh, I know. It's a dish I tasted myself, or have you forgotten? I was ten when I was taken from <a href=\"/index.php/Balon_Greyjoy\" title=\"Balon Greyjoy\">my father's</a> <a href=\"/index.php/Pyke\" title=\"Pyke\">house</a>, to make certain he would raise no more <a href=\"/index.php/Greyjoy%27s_Rebellion\" title=\"Greyjoy&#39;s Rebellion\">rebellions</a>.<sup id=\"cite_ref-Racok66.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_8-1\" class=\"reference\"><a href=\"#cite_note-Racok66.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-8\">&#91;8&#93;</a></sup></p></div><div class=\"templatequotecite\"><cite>&#8212;<a href=\"/index.php/Rodrik_Cassel\" title=\"Rodrik Cassel\">Rodrik Cassel</a> and <a href=\"/index.php/Theon_Greyjoy\" title=\"Theon Greyjoy\">Theon Greyjoy</a></cite></div>\n</blockquote>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p><b>Rodrik</b>: I offer myself in my daughter's place. Release her, and take me as your <a href=\"/index.php/Hostage\" class=\"mw-redirect\" title=\"Hostage\">hostage</a>. Surely the <a href=\"/index.php/Castellan\" title=\"Castellan\">castellan</a> of <a href=\"/index.php/Winterfell\" title=\"Winterfell\">Winterfell</a> is worth more than a child.<br />\n<b>Theon</b>: Not to me.<sup id=\"cite_ref-Racok66.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_8-2\" class=\"reference\"><a href=\"#cite_note-Racok66.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-8\">&#91;8&#93;</a></sup></p></div><div class=\"templatequotecite\"><cite>&#8212;<a href=\"/index.php/Rodrik_Cassel\" title=\"Rodrik Cassel\">Rodrik Cassel</a> and <a href=\"/index.php/Theon_Greyjoy\" title=\"Theon Greyjoy\">Theon Greyjoy</a></cite></div>\n</blockquote>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p>The <a href=\"/index.php/Miller%27s_sons\" title=\"Miller&#39;s sons\">small heads</a> watched him come from their spikes, their tarred and <a href=\"/index.php/Flaying\" title=\"Flaying\">flayed</a> faces looming larger with every yard; between them stood little Beth Cassel, noosed and crying.<sup id=\"cite_ref-Racok66.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_8-3\" class=\"reference\"><a href=\"#cite_note-Racok66.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-8\">&#91;8&#93;</a></sup> </p></div><div class=\"templatequotecite\"><cite>&#8212;thoughts of <a href=\"/index.php/Theon_Greyjoy\" title=\"Theon Greyjoy\">Theon Greyjoy</a></cite></div>\n</blockquote>\n<blockquote class=\"templatequote\" style=\"border-left:none;\"><div class=\"templatequotetext\"><p>She had known a Beth once, back at <a href=\"/index.php/Winterfell\" title=\"Winterfell\">Winterfell</a> when she was <a href=\"/index.php/Arya_Stark\" title=\"Arya Stark\">Arya Stark</a>. Maybe that was why she'd picked the name. Or maybe it was just because it went so well with <i>blind</i>.<sup id=\"cite_ref-Radwd45.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_11-1\" class=\"reference\"><a href=\"#cite_note-Radwd45.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-11\">&#91;11&#93;</a></sup></p></div><div class=\"templatequotecite\"><cite>&#8212;thoughts of \"<a href=\"/index.php/Arya_Stark\" title=\"Arya Stark\">Blind Beth</a>\"</cite></div>\n</blockquote>\n<h2><span class=\"mw-headline\" id=\"References\">References</span><span class=\"mw-editsection\"><span class=\"mw-editsection-bracket\">[</span><a href=\"/index.php?title=Beth_Cassel&amp;action=edit&amp;section=11\" class=\"tw-editsection-onhover\" title=\"Edit section: References\"><span class=\"glyphicon glyphicon-pencil\"></span> </a><span class=\"mw-editsection-bracket\">]</span></span></h2>\n<div class=\"references-small\">\n<div class=\"mw-references-wrap mw-references-columns\"><ol class=\"references\">\n<li id=\"cite_note-1\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-1\">↑</a></span> <span class=\"reference-text\"><i>See the <a href=\"/index.php/Years_after_Aegon%27s_Conquest/Calculations_Ages#Beth_Cassel\" title=\"Years after Aegon&#39;s Conquest/Calculations Ages\">Beth Cassel</a> calculation.</i></span>\n</li>\n<li id=\"cite_note-Rawoiafbeth_cassel.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-2\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Rawoiafbeth_cassel.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-0\">2.0</a></sup> <sup><a href=\"#cite_ref-Rawoiafbeth_cassel.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_2-1\">2.1</a></sup></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_World_of_Ice_and_Fire\" title=\"A World of Ice and Fire\">George R. R. Martin's A World of Ice and Fire</a></i>, Beth Cassel.</span>\n</li>\n<li id=\"cite_note-Ragotappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-3\"><span class=\"mw-cite-backlink\"><a href=\"#cite_ref-Ragotappendix.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D_3-0\">↑</a></span> <span class=\"reference-text\"><i><a href=\"/index.php/A_Game_of_Thrones\" title=\"A Game of Thrones\">A Game of Thrones</a></i>, <a href=\"/index.php/A_Game_of_Thrones-Appendix\" title=\"A Game of Thrones-Appendix\">Appendix</a>.</span>\n</li>\n<li id=\"cite_note-Racok21.7B.7B.7B3.7D.7D.7D.7B.7B.7B4.7D.7D.7D-4\"><span class=\"mw-cite-backlink\">↑ <sup><a href=\"#cite_ref-Racok21.7B.7